const LOCALID_DEVON_EMPLOYEE = 2
const LOCALID_RIVAL1 = 4

mapscripts RustboroCity_DevonCorp_3F_MapScripts {
	MAP_SCRIPT_ON_TRANSITION {
		call_if_eq (VAR_DEVON_CORP_3F_STATE, 0, RustboroCity_DevonCorp_3F_EventScript_SetEmployeePos)
	}
	MAP_SCRIPT_ON_WARP_INTO_MAP_TABLE [
		VAR_DEVON_CORP_3F_STATE, 0: RustboroCity_DevonCorp_3F_EventScript_PlayerFaceEast
	]
	MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_DEVON_CORP_3F_STATE, 0: RustboroCity_DevonCorp_3F_EventScript_MeetPresident
	]
}

script RustboroCity_DevonCorp_3F_EventScript_SetEmployeePos {
	setobjectxyperm (LOCALID_DEVON_EMPLOYEE, 3, 2)
	setobjectmovementtype (LOCALID_DEVON_EMPLOYEE, MOVEMENT_TYPE_FACE_LEFT)
	return
}

script RustboroCity_DevonCorp_3F_EventScript_PlayerFaceEast {
	turnobject (OBJ_EVENT_ID_PLAYER, DIR_EAST)
	end
}

script RustboroCity_DevonCorp_3F_EventScript_MeetPresident {
	lockall
	msgbox (RustboroCity_DevonCorp_3F_Text_ThisIs3rdFloorWaitHere, MSGBOX_DEFAULT)
	closemessage
	applymovement (LOCALID_DEVON_EMPLOYEE, RustboroCity_DevonCorp_3F_Movement_EmployeeWalkOffscreen)
	waitmovement (0)
	applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_FaceLeft)
	applymovement (LOCALID_RIVAL1, Common_Movement_QuestionMark)
	delay (80)
	applymovement (LOCALID_DEVON_EMPLOYEE, RustboroCity_DevonCorp_3F_Movement_EmployeeReturnToPlayer)
	waitmovement (0)
	applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_FaceRight)
	waitmovement (0)
	msgbox (RustboroCity_DevonCorp_3F_Text_WordWithPresidentComeWithMe, MSGBOX_DEFAULT)
	closemessage
	playbgm (MUS_FOLLOW_ME, FALSE)
	applymovement (LOCALID_DEVON_EMPLOYEE, RustboroCity_DevonCorp_3F_Movement_LeadPlayerToPresident)
	applymovement (OBJ_EVENT_ID_PLAYER, RustboroCity_DevonCorp_3F_Movement_PlayerFollowToPresident)
	applymovement (LOCALID_RIVAL1, RustboroCity_DevonCorp_3F_Movement_RivalFollowToPresident)
	waitmovement (0)
	msgbox (RustboroCity_DevonCorp_3F_Text_PleaseGoAhead, MSGBOX_DEFAULT)
	closemessage
	fadedefaultbgm
	applymovement (LOCALID_DEVON_EMPLOYEE, RustboroCity_DevonCorp_3F_Movement_EmployeeFaceDesk)
	applymovement (OBJ_EVENT_ID_PLAYER, RustboroCity_DevonCorp_3F_Movement_PlayerApproachDesk)
	applymovement (LOCALID_RIVAL1, RustboroCity_DevonCorp_3F_Movement_RivalApproachDesk)
	waitmovement (0)
	msgbox (RustboroCity_DevonCorp_3F_Text_MrStoneIHaveFavor, MSGBOX_DEFAULT)
	giveitem (ITEM_LETTER)
	msgbox (RustboroCity_DevonCorp_3F_Text_MrStoneWantYouToHaveThis, MSGBOX_DEFAULT)
	playfanfare (MUS_OBTAIN_ITEM)
	message (RustboroCity_DevonCorp_3F_Text_ReceivedPokenav)
	waitfanfare
	setflag (FLAG_SYS_POKENAV_GET)
	setflag (FLAG_RECEIVED_POKENAV)
	setflag (FLAG_HIDE_RUSTBORO_CITY_POKEMON_SCHOOL_SCOTT)
	msgbox (RustboroCity_DevonCorp_3F_Text_MrStoneExplainPokenavRestUp, MSGBOX_DEFAULT)
	closemessage
	call (Common_EventScript_OutOfCenterPartyHeal)
	msgbox (RustboroCity_DevonCorp_3F_Text_MrStoneGoWithCautionAndCare, MSGBOX_DEFAULT)
	closemessage
	delay (20)
	applymovement (LOCALID_RIVAL1, Common_Movement_WalkInPlaceFasterDown)
	applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_WalkInPlaceFasterUp)
	waitmovement (0)
	msgbox (RustboroCity_DevonCorp_3F_Text_MaybeBrineyCanHelp, MSGBOX_DEFAULT)
	closemessage
	loadword (0, RustboroCity_DevonCorp_3F_EventScript_RivalFollowing)
	setfollower (LOCALID_RIVAL1, CUSTOM_SCRIPT_AND_RUN)
	setflag (FLAG_HIDE_ROUTE_116_WANDAS_BOYFRIEND)
	clearflag (FLAG_HIDE_RUSTURF_TUNNEL_WANDAS_BOYFRIEND)
	clearflag (FLAG_HIDE_RUSTURF_TUNNEL_WANDA)
	clearflag (FLAG_HIDE_BRINEYS_HOUSE_MR_BRINEY)
	clearflag (FLAG_HIDE_BRINEYS_HOUSE_PEEKO)
	setvar (VAR_BRINEY_LOCATION, 1)
	clearflag (FLAG_HIDE_RUSTBORO_CITY_RIVAL)
	setvar (VAR_DEVON_CORP_3F_STATE, 1)
	setvar (VAR_RUSTBORO_CITY_STATE, 6)
	releaseall
	end
}

script RustboroCity_DevonCorp_3F_EventScript_RivalFollowing {
	lock
	facefollower
	msgbox (RustboroCity_DevonCorp_3F_Text_RivalFollowing, MSGBOX_DEFAULT)
	closemessage
	release
	end
}

movement RustboroCity_DevonCorp_3F_Movement_Unused {
	walk_up
	walk_up
	walk_up
	walk_in_place_faster_left
}

movement RustboroCity_DevonCorp_3F_Movement_LeadPlayerToPresident {
	walk_right
	walk_right
	walk_right
	walk_down
	walk_right
	walk_right
	walk_right
	walk_right
	walk_right
	walk_right
	walk_right
	walk_right
	walk_right
	walk_in_place_faster_left
}

movement RustboroCity_DevonCorp_3F_Movement_EmployeeFaceDesk {
	delay_16
	walk_in_place_faster_down
}

movement RustboroCity_DevonCorp_3F_Movement_EmployeeWalkOffscreen {
	walk_right
	walk_right
	walk_right
	walk_down
	walk_right
	walk_right
	walk_right
	walk_right
}

movement RustboroCity_DevonCorp_3F_Movement_EmployeeReturnToPlayer {
	walk_left
	walk_left
	walk_left
	walk_left
	walk_up
	walk_left
	walk_left
	walk_left
}

movement RustboroCity_DevonCorp_3F_Movement_PlayerFollowToPresident {
	walk_right * 4
	walk_down
	walk_right * 8
}

movement RustboroCity_DevonCorp_3F_Movement_RivalFollowToPresident {
	walk_right * 5
	walk_down
	walk_right * 7
}

movement RustboroCity_DevonCorp_3F_Movement_PlayerApproachDesk {
	delay_16 * 2
	walk_down
	walk_down
	walk_in_place_faster_right
}

movement RustboroCity_DevonCorp_3F_Movement_RivalApproachDesk {
	delay_16 * 2
	walk_right
	walk_down
	walk_in_place_faster_right
}

script RustboroCity_DevonCorp_3F_EventScript_MrStone {
	lock
	faceplayer
	goto_if_set (FLAG_RECEIVED_EXP_SHARE, RustboroCity_DevonCorp_3F_EventScript_MrStoneAfterFavor)
	goto_if_set (FLAG_DELIVERED_STEVEN_LETTER, RustboroCity_DevonCorp_3F_EventScript_GiveExpShare)
	msgbox (RustboroCity_DevonCorp_3F_Text_CountingOnYou, MSGBOX_DEFAULT)
	closemessage
	applymovement (VAR_LAST_TALKED, Common_Movement_FaceOriginalDirection)
	waitmovement (0)
	release
	end
}

script RustboroCity_DevonCorp_3F_EventScript_GiveExpShare {
	msgbox (RustboroCity_DevonCorp_3F_Text_ThankYouForDeliveringLetter, MSGBOX_DEFAULT)
	giveitem (ITEM_EXP_SHARE)
	goto_if_eq (VAR_RESULT, FALSE, Common_EventScript_ShowBagIsFull)
	setflag (FLAG_RECEIVED_EXP_SHARE)
	msgbox (RustboroCity_DevonCorp_3F_Text_ExplainExpShare, MSGBOX_DEFAULT)
	closemessage
	applymovement (VAR_LAST_TALKED, Common_Movement_FaceOriginalDirection)
	waitmovement (0)
	release
	end
}

script RustboroCity_DevonCorp_3F_EventScript_MrStoneAfterFavor {
	msgbox (RustboroCity_DevonCorp_3F_Text_NotFamiliarWithTrends, MSGBOX_DEFAULT)
	closemessage
	applymovement (VAR_LAST_TALKED, Common_Movement_FaceOriginalDirection)
	waitmovement (0)
	release
	end
}

script RustboroCity_DevonCorp_3F_EventScript_Employee {
	lock
	faceplayer
	goto_if_set (FLAG_RECEIVED_REPEAT_BALL, RustboroCity_DevonCorp_3F_EventScript_EmployeeBalls)
	msgbox (RustboroCity_DevonCorp_3F_Text_VisitCaptSternShipyard, MSGBOX_DEFAULT)
	release
	end
}

script RustboroCity_DevonCorp_3F_EventScript_EmployeeBalls {
	msgbox (RustboroCity_DevonCorp_3F_Text_RepeatAndTimerHugelyPopular, MSGBOX_DEFAULT)
	release
	end
}

script RustboroCity_DevonCorp_3F_EventScript_RareRocksDisplay {
	msgbox (RustboroCity_DevonCorp_3F_Text_RareRocksDisplay, MSGBOX_SIGN)
	end
}

text RustboroCity_DevonCorp_3F_Text_MrStoneIHaveFavor {
	format ("I'm MR. STONE, the PRESIDENT of\n"
	    "the DEVON CORPORATION.\p"
	    "I'd just got word about you, {PLAYER}!\p"
	    "You saved our staff not just once,\n"
        "but twice!\l"
		"With the help of your friends,\Nof course.\p"
	    "I have a favor to ask of an amazing\n"
	    "group like you.\p"
	    "I understand that you're delivering\n"
	    "a package to SLATEPORT's SHIPYARD.\p"
	    "Well, on the way, could you stop off in\n"
	    "DEWFORD TOWN?\p"
	    "I was hoping that you'd deliver a\n"
	    "LETTER to STEVEN in DEWFORD.")
}

text RustboroCity_DevonCorp_3F_Text_MrStoneWantYouToHaveThis {
	format ("MR. STONE: Now, you should know that\n"
	    "I am a great PRESIDENT.\p"
	    "So, I'd never be so cheap as to ask\n"
	    "a favor for nothing in return.\p"
	    "That's why I want you two to have these!")
}

text RustboroCity_DevonCorp_3F_Text_ReceivedPokenav {
	format ("{PLAYER} received a POKéNAV.")
}

text RustboroCity_DevonCorp_3F_Text_MrStoneExplainPokenavRestUp {
	format ("MR. STONE: That device…\p"
	    "It's a POKéMON NAVIGATOR, or POKéNAV\n"
	    "for short.\p"
	    "It's an indispensable tool for any\n"
	    "TRAINER on an adventure.\p"
	    "It has a map of the HOENN region.\p"
	    "You can check the locations of\n"
	    "DEWFORD and SLATEPORT easily!\p"
	    "By the way, I've heard that sinister\n"
	    "criminals--MAGMA and AQUA, I believe--\l"
	    "have been making trouble far and wide.\p"
	    "I think it would be best if you rested\n"
	    "up before you go on your way.")
}

text RustboroCity_DevonCorp_3F_Text_MrStoneGoWithCautionAndCare {
	format ("MR. STONE: Oh, and I also heard that you have another friend who helped defend my staff member in PETALBURG WOODS.\N"
		"If you see him, could you tell him to come see me?\N"
		"I would like to reward him as well.\p"
		"Alright, {PLAYER}, {RIVAL},"
	    "go with caution and care!")
}

text RustboroCity_DevonCorp_3F_Text_CountingOnYou {
	format ("MR. STONE: I'm counting on you!")
}

text RustboroCity_DevonCorp_3F_Text_ThankYouForDeliveringLetter {
	format ("MR. STONE: You delivered my LETTER?\n"
	    "Thank you kindly!\p"
	    "This is my way of thanking you.\n"
	    "It should help you, a TRAINER.")
}

text RustboroCity_DevonCorp_3F_Text_ExplainExpShare {
	format ("MR. STONE: A POKéMON holding that\n"
	    "EXP. SHARE will be given some of the\l"
	    "EXP Points from battle.\p"
	    "It will get EXP Points even if it didn't\n"
	    "actually battle.\p"
	    "I would say EXP. SHARE is quite useful\n"
	    "for raising weak POKéMON.")
}

text RustboroCity_DevonCorp_3F_Text_NotFamiliarWithTrends {
	format ("MR. STONE: Since my youth, I've immersed\n"
	    "myself in work.\p"
	    "Consequently, I'm not familiar with\n"
	    "trends and that sort of thing.\p"
	    "But do young people all want to be\n"
	    "TRAINERS in the POKéMON LEAGUE?")
}

text RustboroCity_DevonCorp_3F_Text_ThisIs3rdFloorWaitHere {
	format ("This is the DEVON CORPORATION's\n"
	    "third floor.\p"
	    "Our PRESIDENT's OFFICE is on\n"
	    "this floor.\p"
	    "Anyway, I can't tell you how much I'm\n"
	    "grateful for what you've done.\p"
	    "Um… By the way, that parcel\n"
	    "you got back for us…\p"
	    "Could I get you to deliver that to\n"
	    "the SHIPYARD in SLATEPORT?\p"
	    "It would be awful if those robbers\n"
	    "tried to take it again.\p"
	    "Uh… Hehehe, so, uh, could I count\n"
	    "on you to do that for me?\p"
	    "Oh, that's right.\n"
	    "Could you wait here a second?")
}

text RustboroCity_DevonCorp_3F_Text_WordWithPresidentComeWithMe {
	format ("Our PRESIDENT would like to have\n"
	    "a word with you two.\p"
	    "Please come with me.")
}

text RustboroCity_DevonCorp_3F_Text_PleaseGoAhead {
	format ("Please, go ahead.")
}

text RustboroCity_DevonCorp_3F_Text_VisitCaptSternShipyard {
	format ("If you visit the SHIPYARD in SLATEPORT,\n"
	    "you should go see CAPT. STERN.")
}

text RustboroCity_DevonCorp_3F_Text_RepeatAndTimerHugelyPopular {
	format ("DEVON's new products, the REPEAT BALL\n"
	    "and TIMER BALL, have become hugely\l"
	    "popular among TRAINERS.")
}

text RustboroCity_DevonCorp_3F_Text_RareRocksDisplay {
	format ("It's a collection of rare rocks and\n"
	    "stones assembled by the PRESIDENT.")
}

text RustboroCity_DevonCorp_3F_Text_MaybeBrineyCanHelp {
	format ("{RIVAL}: This is so cool!\N"
		"With this map feature, we should have an easier time finding our way.\p"
		"Looks like DEWFORD is on an island across the sea.\N"
		"MR. BRINEY is an old seafarer.\N"
		"Maybe he can help us.\N"
		"Lead the way, {PLAYER}!")
}

text RustboroCity_DevonCorp_3F_Text_RivalFollowing {
	format("Let's go to MR. BRINEY'S cottage on ROUTE 104!")
}
