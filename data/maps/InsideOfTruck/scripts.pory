const LOCALID_SPENCER = 4
const LOCALID_BREN = 5
const LOCALID_KYLE = 6

mapscripts InsideOfTruck_MapScripts {
    MAP_SCRIPT_ON_LOAD: InsideOfTruck_OnLoad
    MAP_SCRIPT_ON_RESUME: InsideOfTruck_OnResume
}

script InsideOfTruck_OnLoad {
    setmetatile (4, 1, METATILE_InsideOfTruck_ExitLight_Top, FALSE)
	setmetatile (4, 2, METATILE_InsideOfTruck_ExitLight_Mid, FALSE)
	setmetatile (4, 3, METATILE_InsideOfTruck_ExitLight_Bottom, FALSE)
    end
}

script InsideOfTruck_OnResume {
    setstepcallback (STEP_CB_TRUCK)
	end
}

script InsideOfTruck_EventScript_SetIntroFlags {
    lockall
	setflag (FLAG_HIDE_MAP_NAME_POPUP)
    checkfriendchoice
    switch (var(VAR_RESULT)) {
        case SPENCER:
            goto (InsideOfTruck_EventScript_SetIntroFlagsSpencer)
        case BREN:
            goto (InsideOfTruck_EventScript_SetIntroFlagsBren)
        case KYLE:
            goto (InsideOfTruck_EventScript_SetIntroFlagsKyle)
    }
	end
}

script InsideOfTruck_EventScript_SetIntroFlagsSpencer {
    setrespawn (HEAL_LOCATION_LITTLEROOT_TOWN_BRENDANS_HOUSE_2F)
	setvar (VAR_LITTLEROOT_INTRO_STATE, 1)
	setflag (FLAG_HIDE_LITTLEROOT_TOWN_BRENS_HOUSE_MOM)
	setflag (FLAG_HIDE_LITTLEROOT_TOWN_SPENCERS_HOUSE_RIVAL_MOM)
	setflag (FLAG_HIDE_LITTLEROOT_TOWN_KYLES_HOUSE_MOM)
	setvar (VAR_LITTLEROOT_HOUSES_STATE_SPENCER, 1)
	setdynamicwarp (MAP_LITTLEROOT_TOWN, 3, 10)
	releaseall
	end
}

script InsideOfTruck_EventScript_SetIntroFlagsBren {
    setrespawn (HEAL_LOCATION_LITTLEROOT_TOWN_MAYS_HOUSE_2F)
	setvar (VAR_LITTLEROOT_INTRO_STATE, 2)
	setflag (FLAG_HIDE_LITTLEROOT_TOWN_SPENCERS_HOUSE_MOM)
	setflag (FLAG_HIDE_LITTLEROOT_TOWN_BRENS_HOUSE_RIVAL_MOM)
	setflag (FLAG_HIDE_LITTLEROOT_TOWN_KYLES_HOUSE_MOM)
	setvar (VAR_LITTLEROOT_HOUSES_STATE_BREN, 1)
	setdynamicwarp (MAP_LITTLEROOT_TOWN, 12, 10)
	releaseall
	end
}

script InsideOfTruck_EventScript_SetIntroFlagsKyle {
    setrespawn (HEAL_LOCATION_LITTLEROOT_TOWN_KYLES_HOUSE_2F)
	setvar (VAR_LITTLEROOT_INTRO_STATE, 3)
	setflag (FLAG_HIDE_LITTLEROOT_TOWN_BRENS_HOUSE_MOM)
	setflag (FLAG_HIDE_LITTLEROOT_TOWN_SPENCERS_HOUSE_MOM)
	setflag (FLAG_HIDE_LITTLEROOT_TOWN_KYLES_HOUSE_RIVAL_MOM)
	setvar (VAR_LITTLEROOT_HOUSES_STATE_KYLE, 1)
	setdynamicwarp (MAP_LITTLEROOT_TOWN, 15, 17)
	releaseall
	end
}

script InsideOfTruck_EventScript_MovingBox {
    msgbox (InsideOfTruck_Text_BoxPrintedWithMonLogo, MSGBOX_SIGN)
	end
}

script InsideOfTruck_EventScript_WakeFriend {
	lock
	delay (15)
	playse (SE_PIN)
	applymovement (VAR_0x8009, Common_Movement_ExclamationMark)
	waitmovement (0)
	waitse
	faceplayer
	msgbox (InsideOfTruck_Text_FriendAwake, MSGBOX_DEFAULT)
	closemessage
	delay (15)
	getplayerxy (VAR_0x8006, VAR_0x8007)
	playse (SE_LEDGE)
	switch (var(VAR_0x8006)) {
		case 1:
			applymovement (VAR_0x8009, InsideOfTruck_Movement_JumpDown)
		case 2:
			applymovement (VAR_0x8009, InsideOfTruck_Movement_JumpRight)
	}
	waitmovement (0)
	waitse
	checkfriendchoice
	switch (var(VAR_RESULT)) {
		case SPENCER:
			if (var(VAR_0x8009) == 5) {
				clearflag (FLAG_HIDE_INTRO_2F_KYLE)
				setdynamicwarp (MAP_LITTLEROOT_TOWN, 15, 17)
				msgbox (InsideOfTruck_Text_BetKyleHasPokemonAlready, MSGBOX_DEFAULT)
			}
			if (var(VAR_0x8009) == 6) {
				clearflag (FLAG_HIDE_INTRO_2F_BREN)
				setdynamicwarp (MAP_LITTLEROOT_TOWN, 12, 10)
				msgbox (InsideOfTruck_Text_BetBrenHasPokemonAlready, MSGBOX_DEFAULT)
			}
		case BREN:
			if (var(VAR_0x8009) == 4) {
				clearflag (FLAG_HIDE_INTRO_2F_KYLE)
				setdynamicwarp (MAP_LITTLEROOT_TOWN, 15, 17)
				msgbox (InsideOfTruck_Text_BetKyleHasPokemonAlready, MSGBOX_DEFAULT)
			}
			if (var(VAR_0x8009) == 6) {
				clearflag (FLAG_HIDE_INTRO_2F_SPENCER)
				setdynamicwarp (MAP_LITTLEROOT_TOWN, 3, 10)
				msgbox (InsideOfTruck_Text_BetSpencerHasPokemonAlready, MSGBOX_DEFAULT)
			}
		case KYLE:
			if (var(VAR_0x8009) == 4) {
				clearflag (FLAG_HIDE_INTRO_2F_BREN)
				setdynamicwarp (MAP_LITTLEROOT_TOWN, 12, 10)
				msgbox (InsideOfTruck_Text_BetBrenHasPokemonAlready, MSGBOX_DEFAULT)
			}
			if (var(VAR_0x8009) == 5) {
				clearflag (FLAG_HIDE_INTRO_2F_SPENCER)
				setdynamicwarp (MAP_LITTLEROOT_TOWN, 3, 10)
				msgbox (InsideOfTruck_Text_BetSpencerHasPokemonAlready, MSGBOX_DEFAULT)
			}
	}
	closemessage
	switch (var(VAR_0x8006)) {
		case 1:
			applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_FaceRight)
			applymovement (VAR_0x8009, InsideOfTruck_Movement_LeaveTruck1)
		case 2:
			applymovement (OBJ_EVENT_ID_PLAYER, InsideOfTruck_Movement_PlayerFaceFreindLeaving)
			applymovement (VAR_0x8009, InsideOfTruck_Movement_LeaveTruck2)
	}
	waitmovement (0)
	playse (SE_EXIT)
	waitse
	removeobject (VAR_0x8009)
	setflag (FLAG_HIDE_SPENCER_IN_TRUCK)
	setflag (FLAG_HIDE_BREN_IN_TRUCK)
	setflag (FLAG_HIDE_KYLE_IN_TRUCK)
	setvar (VAR_LITTLEROOT_RIVAL_STATE, 2)
	release
	end
}

movement InsideOfTruck_Movement_JumpDown {
	jump_in_place_down
}

movement InsideOfTruck_Movement_JumpRight {
	jump_in_place_right
}

movement InsideOfTruck_Movement_LeaveTruck1 {
	walk_fast_right * 3
	set_invisible
}

movement InsideOfTruck_Movement_LeaveTruck2 {
	walk_fast_down
	walk_fast_right * 3
	set_invisible
}

movement InsideOfTruck_Movement_PlayerFaceFreindLeaving {
	delay_8
	face_right
}

text InsideOfTruck_Text_BoxPrintedWithMonLogo {
    format("The box is printed with a POKéMON logo.\pIt's a POKéMON brand moving and\ndelivery service.")
}

text InsideOfTruck_Text_FriendAwake {
	"HUH?\p WAZZAT?!\n"
	"...Oh, it's just you, {PLAYER}.\l"
	"I must have fallen asleep\l"
	"along the way."
}

text InsideOfTruck_Text_BetSpencerHasPokemonAlready {
	"Crud! That's right!\p"
	"We were all supposed to get our first\n"
	"POKéMON from PROF. BIRCH today!\l"
	"I'll bet Spencer has gotten his already..\n"
	"We'd better get going before it's\n"
	"too late!\n"
	"C'mon! I'll race you!"
}

