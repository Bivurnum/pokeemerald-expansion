const LOCALID_MOM = 1
const LOCALID_RIVAL_MOM = 4
const LOCALID_RIVAL = 6

mapscripts LittlerootTown_MaysHouse_1F_MapScripts {
	MAP_SCRIPT_ON_LOAD {
		if (var(VAR_LITTLEROOT_INTRO_STATE) < 7) {
			setmetatile (5, 4, METATILE_BrendansMaysHouse_MovingBox_Open, TRUE)
			setmetatile (5, 2, METATILE_BrendansMaysHouse_MovingBox_Closed, TRUE)
		}
		call_if_set (FLAG_RECEIVED_RUNNING_SHOES, LittlerootTown_MaysHouse_1F_EventScript_CheckShowShoesManual)
	}
	MAP_SCRIPT_ON_TRANSITION {
		switch (var(VAR_LITTLEROOT_INTRO_STATE)) {
			case 4:
				setobjectxyperm (LOCALID_MOM, 1, 8)
				setobjectmovementtype (LOCALID_MOM, MOVEMENT_TYPE_FACE_UP)
			case 6:
				setobjectxyperm (LOCALID_MOM, 2, 4)
				setobjectmovementtype (LOCALID_MOM, MOVEMENT_TYPE_FACE_UP)
			case 7:
				setobjectxyperm (LOCALID_MOM, 6, 5)
				setobjectmovementtype (LOCALID_MOM, MOVEMENT_TYPE_FACE_UP)
		}
	}
	MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_LITTLEROOT_INTRO_STATE, 4 {
			lockall
			setvar (VAR_0x8004, LOCALID_MOM)
			setvar (VAR_0x8005, BREN)
			goto (PlayersHouse_1F_EventScript_EnterHouseMovingIn)
		}
		VAR_LITTLEROOT_INTRO_STATE, 6 {
			lockall
			msgbox (PlayersHouse_1F_Text_GoSetTheClock, MSGBOX_DEFAULT)
			closemessage
			applymovement (OBJ_EVENT_ID_PLAYER, LittlerootTown_MaysHouse_1F_Movement_PushTowardStairs)
			applymovement (LOCALID_MOM, LittlerootTown_MaysHouse_1F_Movement_PushTowardStairs)
			waitmovement (0)
			warp (MAP_LITTLEROOT_TOWN_MAYS_HOUSE_2F, 1, 1)
			waitstate
			releaseall
		}
		VAR_LITTLEROOT_INTRO_STATE, 7 {
			lockall
			setvar (VAR_0x8004, FEMALE)
			setvar (VAR_0x8005, LOCALID_MOM)
			goto (PlayersHouse_1F_EventScript_PetalburgGymReportFemale)
		}
		VAR_LITTLEROOT_HOUSES_STATE_BREN, 1 {
			lockall
			playse (SE_PIN)
			applymovement (LOCALID_RIVAL_MOM, Common_Movement_ExclamationMark)
			waitmovement (0)
			applymovement (LOCALID_RIVAL_MOM, Common_Movement_Delay48)
			waitmovement (0)
			applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_WalkInPlaceFasterRight)
			applymovement (LOCALID_RIVAL_MOM, LittlerootTown_MaysHouse_1F_Movement_RivalMomApproach)
			waitmovement (0)
			special (GetRivalSonDaughterString)
			msgbox (RivalsHouse_1F_Text_OhYoureTheNewNeighborBren, MSGBOX_DEFAULT)
			setflag (FLAG_MET_RIVAL_MOM)
			setvar (VAR_LITTLEROOT_HOUSES_STATE_SPENCER, 2)
			setvar (VAR_LITTLEROOT_HOUSES_STATE_BREN, 2)
			setvar (VAR_LITTLEROOT_HOUSES_STATE_KYLE, 2)
			checkfriendchoice
			switch (var(VAR_RESULT)) {
				case SPENCER:
					setflag(FLAG_HIDE_LITTLEROOT_TOWN_KYLES_HOUSE_TRUCK)
				case KYLE:
					setflag(FLAG_HIDE_LITTLEROOT_TOWN_SPENCERS_HOUSE_TRUCK)
			}
			releaseall
		}
		VAR_LITTLEROOT_RIVAL_STATE, 4 {
			setvar (VAR_LITTLEROOT_RIVAL_STATE, 5)
			setflag (FLAG_HIDE_LITTLEROOT_TOWN_SPENCERS_HOUSE_TRUCK)
			setflag (FLAG_HIDE_LITTLEROOT_TOWN_BRENS_HOUSE_TRUCK)
			setflag (FLAG_HIDE_LITTLEROOT_TOWN_KYLES_HOUSE_TRUCK)
		}
		VAR_LITTLEROOT_HOUSES_STATE_BREN, 18: PlayersHouse_1F_EventScript_GetSSTicketAndSeeLatiTV
	]
}

// Many of the below scripts have no gender check because they assume youre in the correct house

script LittlerootTown_MaysHouse_1F_EventScript_CheckShowShoesManual {
	checkfriendchoice
	if (var(VAR_RESULT) == BREN) {
		setmetatile (6, 7, METATILE_BrendansMaysHouse_BookOnTable, TRUE)
	}
}

script RivalsHouse_1F_EventScript_RivalMom {
	lock
	faceplayer
	goto_if_eq (VAR_LITTLEROOT_RIVAL_STATE, 7, RivalsHouse_1F_EventScript_FriendsLeftForAdventure)
	goto_if_set (FLAG_DEFEATED_RIVAL_ROUTE103, RivalsHouse_1F_EventScript_GoHomeEverySoOften)
	goto_if_set (FLAG_SYS_POKEMON_GET, RivalsHouse_1F_EventScript_RivalIsOnRoute103)
	if (var(VAR_LITTLEROOT_RIVAL_STATE) == 19) {
		msgbox (RivalsHouse_1F_Text_TooBusyToNoticeVisit, MSGBOX_DEFAULT)
		release
		end
	}
	special (GetRivalSonDaughterString)
	random (3)
	switch (var(VAR_RESULT)) {
		case 0:
			msgbox (RivalsHouse_1F_Text_HopeEnoughToEat, MSGBOX_DEFAULT)
		case 1:
			msgbox (RivalsHouse_1F_Text_BoysBehaving, MSGBOX_DEFAULT)
		case 2:
			msgbox (RivalsHouse_1F_Text_MomSettlingIn, MSGBOX_DEFAULT)
	}
	release
	end
}

script RivalsHouse_1F_EventScript_FriendsLeftForAdventure {
	checkfriendchoice
	switch (var(VAR_RESULT)) {
		case SPENCER:
			msgbox (RivalsHouse_1F_Text_KyleAndBrenLeft, MSGBOX_DEFAULT)
		case BREN:
			msgbox (RivalsHouse_1F_Text_SpencerAndKyleLeft, MSGBOX_DEFAULT)
		case KYLE:
			msgbox (RivalsHouse_1F_Text_SpencerAndBrenLeft, MSGBOX_DEFAULT)
	}
	release
	end
}

script RivalsHouse_1F_EventScript_GoHomeEverySoOften {
	msgbox (RivalsHouse_1F_Text_ShouldGoHomeEverySoOften, MSGBOX_DEFAULT)
	release
	end
}

script RivalsHouse_1F_EventScript_RivalIsOnRoute103 {
	msgbox (RivalsHouse_1F_Text_WentOutToRoute103, MSGBOX_DEFAULT)
	release
	end
}

script LittlerootTown_MaysHouse_1F_EventScript_GoSeeRoom {
	lockall
	setvar (VAR_0x8004, LOCALID_MOM)
	setvar (VAR_0x8005, FEMALE)
	applymovement (VAR_0x8004, Common_Movement_WalkInPlaceFasterRight)
	waitmovement (0)
	goto (PlayersHouse_1F_EventScript_MomGoSeeRoom)
	end
}

movement LittlerootTown_MaysHouse_1F_Movement_PushTowardStairs {
	walk_up
}

movement LittlerootTown_MaysHouse_1F_Movement_RivalMomApproach {
	walk_down
	walk_left * 5
}

text RivalsHouse_1F_Text_OhYoureTheNewNeighborSpencer {
	"Oh, hello, {PLAYER}!\p"
	"If you're looking for SPENCER,\n"
	"I think he may still be in\l"
	"the moving truck.\p"
	"Would you go and check on him\n"
	"for me, please?"
}

text RivalsHouse_1F_Text_OhYoureTheNewNeighborBren {
	"Oh, hello, {PLAYER}!\p"
	"If you're looking for BREN,\n"
	"I think he may still be in\l"
	"the moving truck.\p"
	"Would you go and check on him\n"
	"for me, please?"
}

