text RivalsHouse_1F_Text_HopeEnoughToEat {
	"I sure hope my son is\n"
	"getting enough to eat."
}

text RivalsHouse_1F_Text_BoysBehaving {
	"Are you boys behaving?"
}

text RivalsHouse_1F_Text_MomSettlingIn {
	"How is your mom settling in?"
}

text RivalsHouse_1F_Text_TooBusyToNoticeVisit {
	"That {RIVAL}!\p"
	"I guess our child is too busy with\n"
	"POKéMON to notice that you came\l"
	"to visit, {PLAYER}{KUN}."
}

text RivalsHouse_1F_Text_WentOutToRoute103 {
	"Oh, {RIVAL} went out to ROUTE 103\n"
	"just a little while ago.\p"
	"Like father, like child.\n"
	"{RIVAL} can't stay quietly at home."
}

text RivalsHouse_1F_Text_ShouldGoHomeEverySoOften {
	"I think it's wonderful for people to\n"
	"travel with POKéMON.\p"
	"But you should go home every so often\n"
	"to let your mother know you're okay.\p"
	"She might not say it, but I'm sure she\n"
	"worries about you, {PLAYER}{KUN}."
}

text RivalsHouse_1F_Text_SpencerAndBrenLeft {
	"Oh hey, {PLAYER}.\n"
	"SPENCER and BREN said they were headed\l"
	"out to train up their new POKéMON."
	"You should join them when you're ready."
}

