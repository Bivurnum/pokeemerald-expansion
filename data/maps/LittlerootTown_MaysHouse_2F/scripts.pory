const LOCALID_RIVAL = 1
const LOCALID_FRIEND = 15

mapscripts LittlerootTown_MaysHouse_2F_MapScripts {
	MAP_SCRIPT_ON_TRANSITION {
		if (var(VAR_LITTLEROOT_RIVAL_STATE) >= 19) {
			goto_if_set (FLAG_MET_RIVAL_LILYCOVE, LittlerootTown_MaysHouse_2F_EventScript_TryUpdateMayPos)
			goto_if_ge (VAR_BIRCH_LAB_STATE, 2, LittlerootTown_MaysHouse_2F_EventScript_Ret)
			goto (LittlerootTown_MaysHouse_2F_EventScript_TryUpdateMayPos)
		}
		call_if_eq (VAR_LITTLEROOT_INTRO_STATE, 5, PlayersHouse_2F_EventScript_BlockStairsUntilClockIsSet)
		call (SecretBase_EventScript_SetDecorationFlags)
		setvar (VAR_SECRET_BASE_INITIALIZED, 0)
	}
	MAP_SCRIPT_ON_WARP_INTO_MAP_TABLE [
		VAR_SECRET_BASE_INITIALIZED, 0 {
			checkfriendchoice
			goto_if_eq (VAR_RESULT, BREN, SecretBase_EventScript_InitDecorations)
		}
	]
}

script LittlerootTown_MaysHouse_2F_EventScript_TryUpdateMayPos {
	checkfriendchoice
	goto_if_eq (VAR_RESULT, FEMALE, LittlerootTown_MaysHouse_2F_EventScript_Ret)
	goto_if_ge (VAR_DEX_UPGRADE_JOHTO_STARTER_STATE, 2, LittlerootTown_MaysHouse_2F_EventScript_Ret)
	setobjectxyperm (LOCALID_RIVAL, 8, 2)
	setobjectmovementtype (LOCALID_RIVAL, MOVEMENT_TYPE_FACE_UP)
	return
}

script LittlerootTown_MaysHouse_2F_EventScript_Ret {
	return
}

script LittlerootTown_MaysHouse_2F_EventScript_FriendRival {
	lockall
	faceplayer
	if (var(VAR_LITTLEROOT_RIVAL_STATE) == 5) {
		msgbox (RivalsHouse_2F_Text_GoFindBirch, MSGBOX_DEFAULT)
		closemessage
		applymovement (LOCALID_FRIEND, Common_Movement_FaceUp)
		waitmovement (0)
		setvar (VAR_LITTLEROOT_RIVAL_STATE, 6)
	}
	elif (var(VAR_LITTLEROOT_RIVAL_STATE) == 6) {
		msgbox (RivalsHouse_2F_Text_HesOnRoute101, MSGBOX_DEFAULT)
		closemessage
		applymovement (LOCALID_FRIEND, Common_Movement_FaceUp)
		waitmovement (0)
	}
	setvar (VAR_LITTLEROOT_TOWN_STATE, 1)
	releaseall
	end
}

script RivalsHouse_2F_EventScript_RivalPostLilycove {
	applymovement (VAR_LAST_TALKED, Common_Movement_FacePlayer)
	waitmovement (0)
	checkfriendchoice
	call_if_eq (VAR_RESULT, SPENCER, RivalsHouse_2F_EventScript_MayPostLilycove)
	call_if_eq (VAR_RESULT, BREN, RivalsHouse_2F_EventScript_BrendanPostLilycove)
	setflag (FLAG_MET_RIVAL_IN_HOUSE_AFTER_LILYCOVE)
	releaseall
	end
}

script RivalsHouse_2F_EventScript_MayPostLilycove {
	goto_if_set (FLAG_MET_RIVAL_IN_HOUSE_AFTER_LILYCOVE, RivalsHouse_2F_EventScript_MayWhereShouldIGoNext)
	msgbox (RivalsHouse_2F_Text_MayJustCheckingMyPokedex, MSGBOX_DEFAULT)
	return
}

script RivalsHouse_2F_EventScript_BrendanPostLilycove {
	goto_if_set (FLAG_MET_RIVAL_IN_HOUSE_AFTER_LILYCOVE, RivalsHouse_2F_EventScript_BrendanWhereShouldIGoNext)
	msgbox (RivalsHouse_2F_Text_BrendanJustCheckingMyPokedex, MSGBOX_DEFAULT)
	return
}

script RivalsHouse_2F_EventScript_MayWhereShouldIGoNext {
	msgbox (RivalsHouse_2F_Text_MayWhereShouldIGoNext, MSGBOX_DEFAULT)
	return
}

script RivalsHouse_2F_EventScript_BrendanWhereShouldIGoNext {
	msgbox (RivalsHouse_2F_Text_BrendanWhereShouldIGoNext, MSGBOX_DEFAULT)
	return
}

script LittlerootTown_MaysHouse_2F_EventScript_PC {
	lockall
	checkfriendchoice
	if (var(VAR_RESULT) == BREN) {
		goto (LittlerootTown_MaysHouse_2F_EventScript_CheckPlayersPC)
	}
	else {
		goto (LittlerootTown_MaysHouse_2F_EventScript_CheckRivalsPC)
	}
}

script LittlerootTown_MaysHouse_2F_EventScript_CheckRivalsPC {
	msgbox (gText_PokemonTrainerSchoolEmail, MSGBOX_DEFAULT)
	releaseall
	end
}

script LittlerootTown_MaysHouse_2F_EventScript_CheckPlayersPC {
	setvar (VAR_0x8004, PC_LOCATION_MAYS_HOUSE)
	special (DoPCTurnOnEffect)
	playse (SE_PC_ON)
	msgbox (gText_PlayerHouseBootPC, MSGBOX_DEFAULT)
	special (BedroomPC)
	waitstate
	releaseall
	end
}

script LittlerootTown_MaysHouse_2F_EventScript_TurnOffPlayerPC {
	setvar (VAR_0x8004, PC_LOCATION_MAYS_HOUSE)
	playse (SE_PC_OFF)
	special (DoPCTurnOffEffect)
	releaseall
	end
}

text RivalsHouse_2F_Text_MayJustCheckingMyPokedex {
	"MAY: {PLAYER}{KUN}!\p"
	"I was just checking my POKéDEX.\p"
	"There's still a lot of POKéMON that\n"
	"I've seen but haven't caught.\p"
	"And there are many others that\n"
	"I think will evolve.\p"
	"I wonder where I should go catch\n"
	"some POKéMON next?"
}

text RivalsHouse_2F_Text_MayWhereShouldIGoNext {
	"MAY: I wonder where I should go catch\n"
	"some POKéMON next?\p"
	"Wouldn't it be funny if we ran into each\n"
	"other, {PLAYER}{KUN}?"
}

text RivalsHouse_2F_Text_BrendanJustCheckingMyPokedex {
	"BRENDAN: Hey, it's {PLAYER}.\p"
	"I was just checking out my POKéDEX.\p"
	"There are still many POKéMON that\n"
	"I need to catch, I know, but this\l"
	"is looking pretty good.\p"
	"Checking this POKéDEX out gives me\n"
	"the urge to hit the road again."
}

text RivalsHouse_2F_Text_BrendanWhereShouldIGoNext {
	"BRENDAN: I'm having a hard time deciding\n"
	"where I should catch POKéMON next.\p"
	"Hey, {PLAYER}, if I see you while I'm out\n"
	"catching POKéMON, I can pitch you a\l"
	"battle if you'd like."
}

text RivalsHouse_2F_Text_GoFindBirch {
	"Oh, hey!\p"
	"Isn't it crazy that the three of us\n"
	"all moved here at the same time?\l"
	"Now we all get to start our POKéMON\l"
	"journey together!\p"
	"What?\n"
	"You don't have a POKéMON yet?\p"
	"I've got mine already.\n"
	"Maybe I'll show it to you sometime.\p"
	"Well? What are you waiting for?\n"
	"Go find PROF. BIRCH and\l"
	"get your first POKéMON!"
}

text RivalsHouse_2F_Text_HesOnRoute101 {
	"Last I heard, PROF. BIRCH was\n"
	"doing field work on ROUTE 101."
}
