const LOCALID_MOM = 1
const LOCALID_RIVAL_MOM = 4
const LOCALID_RIVAL = 6

mapscripts LittlerootTown_KylesHouse_1F_MapScripts {
	MAP_SCRIPT_ON_LOAD {
		if (var(VAR_LITTLEROOT_INTRO_STATE) < 7) {
			setmetatile (5, 4, METATILE_BrendansMaysHouse_MovingBox_Open, TRUE)
			setmetatile (5, 2, METATILE_BrendansMaysHouse_MovingBox_Closed, TRUE)
		}
		call_if_set (FLAG_RECEIVED_RUNNING_SHOES, LittlerootTown_KylesHouse_1F_EventScript_CheckShowShoesManual)
	}
	MAP_SCRIPT_ON_TRANSITION {
		switch (var(VAR_LITTLEROOT_INTRO_STATE)) {
			case 4:
				setobjectxyperm (LOCALID_MOM, 1, 8)
				setobjectmovementtype (LOCALID_MOM, MOVEMENT_TYPE_FACE_UP)
			case 6:
				setobjectxyperm (LOCALID_MOM, 2, 4)
				setobjectmovementtype (LOCALID_MOM, MOVEMENT_TYPE_FACE_UP)
			case 7:
				setobjectxyperm (LOCALID_MOM, 6, 5)
				setobjectmovementtype (LOCALID_MOM, MOVEMENT_TYPE_FACE_UP)
		}
	}
	MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_LITTLEROOT_INTRO_STATE, 4 {
			lockall
			setvar (VAR_0x8004, LOCALID_MOM)
			setvar (VAR_0x8005, KYLE)
			goto (PlayersHouse_1F_EventScript_EnterHouseMovingIn)
		}
		VAR_LITTLEROOT_INTRO_STATE, 6 {
			lockall
			msgbox (PlayersHouse_1F_Text_GoSetTheClock, MSGBOX_DEFAULT)
			closemessage
			applymovement (OBJ_EVENT_ID_PLAYER, LittlerootTown_KylesHouse_1F_Movement_PushTowardStairs)
			applymovement (LOCALID_MOM, LittlerootTown_KylesHouse_1F_Movement_PushTowardStairs)
			waitmovement (0)
			warp (MAP_LITTLEROOT_TOWN_KYLES_HOUSE_2F, 1, 1)
			waitstate
			releaseall
		}
		VAR_LITTLEROOT_INTRO_STATE, 7 {
			lockall
			setvar (VAR_0x8004, KYLE)
			setvar (VAR_0x8005, LOCALID_MOM)
			goto (PlayersHouse_1F_EventScript_PetalburgGymReportFemale)
		}
		VAR_LITTLEROOT_HOUSES_STATE_SPENCER, 1 {
			lockall
			playse (SE_PIN)
			applymovement (LOCALID_RIVAL_MOM, Common_Movement_ExclamationMark)
			waitmovement (0)
			applymovement (LOCALID_RIVAL_MOM, Common_Movement_Delay48)
			waitmovement (0)
			applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_WalkInPlaceFasterLeft)
			applymovement (LOCALID_RIVAL_MOM, LittlerootTown_KylesHouse_1F_Movement_RivalMomApproach)
			waitmovement (0)
			special (GetRivalSonDaughterString)
			msgbox (RivalsHouse_1F_Text_OhYoureTheNewNeighbor, MSGBOX_DEFAULT)
			setflag (FLAG_MET_RIVAL_MOM)
			setvar (VAR_LITTLEROOT_HOUSES_STATE_SPENCER, 2)
			releaseall
		}
		VAR_LITTLEROOT_HOUSES_STATE_BREN, 3: PlayersHouse_1F_EventScript_GetSSTicketAndSeeLatiTV
	]
}

// Many of the below scripts have no gender check because they assume youre in the correct house

script LittlerootTown_KylesHouse_1F_EventScript_CheckShowShoesManual {
	checkfriendchoice
	if (var(VAR_RESULT) == BREN) {
		setmetatile (6, 7, METATILE_BrendansMaysHouse_BookOnTable, TRUE)
	}
}

script LittlerootTown_KylesHouse_1F_EventScript_GoSeeRoom {
	lockall
	setvar (VAR_0x8004, LOCALID_MOM)
	setvar (VAR_0x8005, FEMALE)
	applymovement (VAR_0x8004, Common_Movement_WalkInPlaceFasterRight)
	waitmovement (0)
	goto (PlayersHouse_1F_EventScript_MomGoSeeRoom)
	end
}

script LittlerootTown_KylesHouse_1F_EventScript_MeetRival0 {
	lockall
	setvar (VAR_0x8008, 0)
	goto (LittlerootTown_KylesHouse_1F_EventScript_MeetRival)
	end
}

script LittlerootTown_KylesHouse_1F_EventScript_MeetRival1 {
	lockall
	setvar (VAR_0x8008, 1)
	goto (LittlerootTown_KylesHouse_1F_EventScript_MeetRival)
	end
}

script LittlerootTown_KylesHouse_1F_EventScript_MeetRival2 {
	lockall
	setvar (VAR_0x8008, 2)
	goto (LittlerootTown_KylesHouse_1F_EventScript_MeetRival)
	end
}

script LittlerootTown_KylesHouse_1F_EventScript_MeetRival {
	playse (SE_EXIT)
	delay (10)
	addobject (LOCALID_RIVAL)
	delay (30)
	playse (SE_PIN)
	applymovement (LOCALID_RIVAL, Common_Movement_ExclamationMark)
	waitmovement (0)
	applymovement (LOCALID_RIVAL, Common_Movement_Delay48)
	waitmovement (0)
	if (var(VAR_0x8008) != 1) {
		applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_WalkInPlaceFasterDown)
		waitmovement (0)
	}
	playbgm (MUS_ENCOUNTER_MAY, TRUE)
	switch (var(VAR_0x8008)) {
		case 0:
			applymovement (LOCALID_RIVAL, LittlerootTown_KylesHouse_1F_Movement_MayApproachPlayer0)
		case 1:
			applymovement (LOCALID_RIVAL, LittlerootTown_KylesHouse_1F_Movement_MayApproachPlayer1)
		case 2:
			applymovement (LOCALID_RIVAL, LittlerootTown_KylesHouse_1F_Movement_MayApproachPlayer2)
	}
	waitmovement (0)
	msgbox (RivalsHouse_1F_Text_MayWhoAreYou, MSGBOX_DEFAULT)
	closemessage
	switch (var(VAR_0x8008)) {
		case 0:
			applymovement (OBJ_EVENT_ID_PLAYER, LittlerootTown_KylesHouse_1F_Movement_PlayerWatchMayExit0)
			applymovement (LOCALID_RIVAL, LittlerootTown_KylesHouse_1F_Movement_MayGoUpstairs0)
		case 1:
			applymovement (OBJ_EVENT_ID_PLAYER, LittlerootTown_KylesHouse_1F_Movement_PlayerWatchMayExit1)
			applymovement (LOCALID_RIVAL, LittlerootTown_KylesHouse_1F_Movement_MayGoUpstairs1)
		case 2:
			applymovement (OBJ_EVENT_ID_PLAYER, LittlerootTown_KylesHouse_1F_Movement_PlayerWatchMayExit2)
			applymovement (LOCALID_RIVAL, LittlerootTown_KylesHouse_1F_Movement_MayGoUpstairs2)
	}
	waitmovement (0)
	playse (SE_EXIT)
	removeobject (LOCALID_RIVAL)
	setflag (FLAG_HIDE_LITTLEROOT_TOWN_MAYS_HOUSE_MAY)
	clearflag (FLAG_HIDE_LITTLEROOT_TOWN_MAYS_HOUSE_RIVAL_BEDROOM)
	delay (30)
	setvar (VAR_LITTLEROOT_RIVAL_STATE, 3)
	setvar (VAR_LITTLEROOT_TOWN_STATE, 1)
	savebgm (MUS_DUMMY)
	fadedefaultbgm
	releaseall
	end
}

movement LittlerootTown_KylesHouse_1F_Movement_PushTowardStairs {
	walk_up
}

movement LittlerootTown_KylesHouse_1F_Movement_RivalMomApproach {
	walk_down
	walk_left * 5
}

movement LittlerootTown_KylesHouse_1F_Movement_MayApproachPlayer0 {
	walk_in_place_faster_left
	walk_left
	walk_in_place_faster_up
	walk_up * 4
}

movement LittlerootTown_KylesHouse_1F_Movement_MayApproachPlayer1 {
	walk_up * 3
}

movement LittlerootTown_KylesHouse_1F_Movement_MayApproachPlayer2 {
	walk_in_place_faster_right
	walk_right
	walk_in_place_faster_up
	walk_up * 4
}

movement LittlerootTown_KylesHouse_1F_Movement_PlayerWatchMayExit0 {
	delay_16
	delay_8
	walk_in_place_faster_right
}

movement LittlerootTown_KylesHouse_1F_Movement_PlayerWatchMayExit1 {
	delay_16
	delay_8
	walk_in_place_faster_right
	delay_16 * 2
	walk_in_place_faster_up
}

movement LittlerootTown_KylesHouse_1F_Movement_PlayerWatchMayExit2 {
	delay_16
	delay_8
	walk_in_place_faster_left
}

movement LittlerootTown_KylesHouse_1F_Movement_MayGoUpstairs0 {
	walk_in_place_faster_right
	walk_right
	walk_in_place_faster_up
	walk_up * 2
}

movement LittlerootTown_KylesHouse_1F_Movement_MayGoUpstairs1 {
	walk_in_place_faster_right
	walk_right
	walk_in_place_faster_up
	walk_up * 2
	walk_in_place_faster_left
	walk_left
	walk_in_place_faster_up
	walk_up
}

movement LittlerootTown_KylesHouse_1F_Movement_MayGoUpstairs2 {
	walk_in_place_faster_left
	walk_left
	walk_in_place_faster_up
	walk_up * 2
}