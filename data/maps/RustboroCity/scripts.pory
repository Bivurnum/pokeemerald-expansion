text RustboroCity_Text_YoPlayer {
	format ("Yo! {PLAYER}!")
}

text RustboroCity_Text_WhatsGoingOn {
	format ("I heard there was a commotion going on here. "
		"What's going on?")
}

text RustboroCity_Text_GuyGotMugged {
	format ("So this guy got mugged? That's absolutely despicable!")
}

text RustboroCity_Text_DontWorrySir {
	format ("Don't worry, sir. {PLAYER} and I will get your GOODS back.")
}

text RustboroCity_Text_ThankBothOfYou {
	format ("Oh, thank you! Both of you!\n"
		"I do hope you can get them back.")
}

text RustboroCity_Text_LetsGoCatchMugger {
	format ("C'mon, {PLAYER}!\n"
		"Let's go catch that mugger!")
}

script RustboroCity_EventScript_ReturnGoodsTrigger0 {
	lockall
	setvar (VAR_TEMP_1, 0)
	call (RustboroCity_EventScript_EmployeeFacePlayerUp2)
	goto (RustboroCity_EventScript_ReturnGoods)
	end
}

