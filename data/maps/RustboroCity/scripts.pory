const LOCALID_LITTLE_BOY = 7
const LOCALID_LITTLE_GIRL = 8
const LOCALID_DEVON_EMPLOYEE = 9
const LOCALID_GRUNT = 10
const LOCALID_RIVAL2 = 14
const LOCALID_SCIENTIST = 15
const LOCALID_RIVAL1 = 17

raw `
.set LOCALID_LITTLE_BOY, 7
.set LOCALID_LITTLE_GIRL, 8
.set LOCALID_DEVON_EMPLOYEE, 9
.set LOCALID_GRUNT, 10
.set LOCALID_RIVAL2, 14
.set LOCALID_SCIENTIST, 15
.set LOCALID_RIVAL1, 17
`

	// State descriptions for VAR_RUSTBORO_CITY_STATE
	// 1: Defeated Roxanne
	// 2: Watched GOODS get stolen
	// 3: Asked to get GOODS back
	// 4: Saved PEEKO
	// 5: Returned GOODS
	// 6: Received Pokenav
	// 7: Completed Match Call tutorial
	// 8: Defeated Rival2

mapscripts RustboroCity_MapScripts {
	MAP_SCRIPT_ON_TRANSITION {
		setflag (FLAG_VISITED_RUSTBORO_CITY)
		call (Common_EventScript_SetupRivalGfxId)
		call_if_eq (VAR_RUSTBORO_CITY_STATE, 1, RustboroCity_EventScript_SetRivalForRetrieveGoods)
		call_if_eq (VAR_RUSTBORO_CITY_STATE, 2, RustboroCity_EventScript_SetRivalForRetrieveGoods)
		call_if_eq (VAR_RUSTBORO_CITY_STATE, 4, RustboroCity_EventScript_SetForReturnGoods)
		call_if_eq (VAR_RUSTBORO_CITY_STATE, 6, RustboroCity_EventScript_HideMapNamePopup)
		getplayerxy (VAR_TEMP_0, VAR_TEMP_1)
		goto_if_eq (VAR_RUSTBORO_CITY_STATE, 6, RustboroCity_EventScript_PositionScientistForExit)
	}
	MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_RUSTBORO_CITY_STATE, 6: RustboroCity_EventScript_ScientistAddMatchCall
	]
}

script RustboroCity_EventScript_PositionScientistForExit {
	goto_if_eq (VAR_TEMP_0, 11, RustboroCity_EventScript_PositionScientistLeftExit)
	setobjectxyperm (LOCALID_SCIENTIST, 11, 15)
	setobjectxyperm (LOCALID_RIVAL1, 11, 15)
	setobjectmovementtype (LOCALID_RIVAL1, MOVEMENT_TYPE_FACE_DOWN)
	end
}

script RustboroCity_EventScript_PositionScientistLeftExit {
	setobjectxyperm (LOCALID_SCIENTIST, 12, 15)
	setobjectxyperm (LOCALID_RIVAL1, 12, 15)
	setobjectmovementtype (LOCALID_RIVAL1, MOVEMENT_TYPE_FACE_DOWN)
	end
}

script RustboroCity_EventScript_HideMapNamePopup {
	setflag (FLAG_HIDE_MAP_NAME_POPUP)
	return
}

script RustboroCity_EventScript_SetRivalForRetrieveGoods {
	setobjectxyperm (LOCALID_RIVAL1, 21, 10)
}

script RustboroCity_EventScript_SetForReturnGoods {
	setobjectmovementtype (LOCALID_DEVON_EMPLOYEE, MOVEMENT_TYPE_FACE_LEFT)
}

script RustboroCity_EventScript_ScientistAddMatchCall {
	lockall
	setvar (VAR_ROUTE104_STATE, 1)
	destroyfollower
	playse (SE_EXIT)
	delay (10)
	addobject (LOCALID_RIVAL1)
	applymovement (LOCALID_RIVAL1, Common_Movement_WalkDown)
	waitmovement (0)
	applymovement (OBJ_EVENT_ID_PLAYER, RustboroCity_Movement_PlayerWalkDown)
	applymovement (LOCALID_RIVAL1, RustboroCity_Movement_PlayerWalkDown)
	waitmovement (0)
	playse (SE_EXIT)
	delay (10)
	addobject (LOCALID_SCIENTIST)
	applymovement (LOCALID_SCIENTIST, RustboroCity_Movement_ScientistApproachPlayer)
	waitmovement (0)
	playse (SE_PIN)
	applymovement (LOCALID_SCIENTIST, Common_Movement_ExclamationMark)
	waitmovement (0)
	applymovement (LOCALID_SCIENTIST, Common_Movement_Delay48)
	waitmovement (0)
	applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_WalkInPlaceFasterUp)
	applymovement (LOCALID_RIVAL1, Common_Movement_WalkInPlaceFasterUp)
	waitmovement (0)
	applymovement (LOCALID_SCIENTIST, RustboroCity_Movement_ScientistWalkInPlaceDown)
	waitmovement (0)
	msgbox (RustboroCity_Text_DevelopedNewPokenavFeature, MSGBOX_DEFAULT)
	closemessage
	setflag (FLAG_HAS_MATCH_CALL)
	getplayerxy (VAR_TEMP_0, VAR_TEMP_1)
	if (var(VAR_TEMP_0) == 11) {
		applymovement (LOCALID_SCIENTIST, Common_Movement_WalkInPlaceFasterRight)
		waitmovement (0)
		call (RustboroCity_EventScript_UpdatePokenav)
		applymovement (LOCALID_SCIENTIST, RustboroCity_Movement_GoToPlayerUpgradeLeft)
		waitmovement (0)
	}
	else {
		applymovement (LOCALID_SCIENTIST, Common_Movement_WalkInPlaceFasterLeft)
		waitmovement (0)
		call (RustboroCity_EventScript_UpdatePokenav)
		applymovement (LOCALID_SCIENTIST, RustboroCity_Movement_GoToPlayerUpgradeRight)
		waitmovement (0)
	}
	call (RustboroCity_EventScript_UpdatePokenav)
	applymovement (LOCALID_SCIENTIST, Common_Movement_WalkInPlaceFasterDown)
	waitmovement (0)
	msgbox (RustboroCity_Text_AddedMatchCallPleaseCallMrStone, MSGBOX_DEFAULT)
	closemessage
	delay (20)
	goto (RustboroCity_EventScript_MatchCallTutorial)
}

script RustboroCity_EventScript_UpdatePokenav {
	playse (SE_CLICK)
	delay (10)
	playse (SE_CLICK)
	delay (10)
	playse (SE_CLICK)
	delay (10)
	playse (SE_CLICK)
	delay (20)
	return
}

script RustboroCity_EventScript_PleaseSelectPokenav {
	msgbox (RustboroCity_Text_PleaseSelectPokenav, MSGBOX_DEFAULT)
	closemessage
	delay (10)
	goto (RustboroCity_EventScript_MatchCallTutorial)
}

script RustboroCity_EventScript_MatchCallTutorial {
	setflag (FLAG_ADDED_MATCH_CALL_TO_POKENAV)
	special (ScriptMenu_CreateStartMenuForPokenavTutorial)
	waitstate
	switch (var(VAR_RESULT)) {
		case 0:
			goto (RustboroCity_EventScript_PleaseSelectPokenav)
		case 1:
			goto (RustboroCity_EventScript_PleaseSelectPokenav)
		case 2:
			goto (RustboroCity_EventScript_PleaseSelectPokenav)
		case 4:
			goto (RustboroCity_EventScript_PleaseSelectPokenav)
		case 5:
			goto (RustboroCity_EventScript_PleaseSelectPokenav)
		case 6:
			goto (RustboroCity_EventScript_PleaseSelectPokenav)
		case 7:
			goto (RustboroCity_EventScript_PleaseSelectPokenav)
		case MULTI_B_PRESSED:
			goto (RustboroCity_EventScript_PleaseSelectPokenav)
	}
	special (OpenPokenavForTutorial)
	waitstate
	delay (20)
	msgbox (RustboroCity_Text_IdBetterGetBackToWork, MSGBOX_DEFAULT)
	closemessage
	applymovement (LOCALID_SCIENTIST, RustboroCity_Movement_ScientistLeave)
	waitmovement (0)
	playse (SE_EXIT)
	removeobject (LOCALID_SCIENTIST)
	waitse
	delay (30)
	getplayerxy (VAR_TEMP_0, VAR_TEMP_1)
	if (var(VAR_TEMP_0) == 11) {
		applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_WalkInPlaceRight)
		applymovement (LOCALID_RIVAL1, Common_Movement_WalkInPlaceLeft)
	}
	else {
		applymovement (LOCALID_RIVAL1, Common_Movement_WalkInPlaceRight)
		applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_WalkInPlaceLeft)
	}
	waitmovement (0)
	msgbox (RustboroCity_Text_Rival1LetsRegister, MSGBOX_DEFAULT)
	closemessage
	delay (30)
	playfanfare (MUS_REGISTER_MATCH_CALL)
	msgbox (RustboroCity_Text_RegisteredRival1, MSGBOX_DEFAULT)
	waitfanfare
	closemessage
	delay (30)
	checkfriendchoice
	switch (var(VAR_RESULT)) {
		case SPENCER:
			setflag (FLAG_ENABLE_BREN_MATCH_CALL)
		case BREN:
			setflag (FLAG_ENABLE_KYLE_MATCH_CALL)
		case KYLE:
			setflag (FLAG_ENABLE_SPENCER_MATCH_CALL)
	}
	msgbox (RustboroCity_Text_SeeYouSoon, MSGBOX_DEFAULT)
	closemessage
	applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_FaceDown)
	applymovement (LOCALID_RIVAL1, RustboroCity_Movement_Rival1LeaveAfterPokenav)
	waitmovement (0)
	removeobject (LOCALID_RIVAL1)
	setflag (FLAG_HIDE_RUSTBORO_CITY_SCIENTIST)
	setflag (FLAG_HIDE_DEVON_3F_RIVAL1)
	setvar (VAR_RUSTBORO_CITY_STATE, 7)
	clearflag (FLAG_HIDE_MAP_NAME_POPUP)
	releaseall
	end
}

movement RustboroCity_Movement_ScientistWalkInPlaceDown {
	walk_in_place_down
}

movement RustboroCity_Movement_PlayerWalkDown {
	walk_down
}

movement RustboroCity_Movement_ScientistApproachPlayer {
	walk_down
	delay_16
}

// Unused
movement RustboroCity_Movement_ScientistWalkAroundPlayer {
	delay_16
	walk_left
	walk_down
	walk_down
	walk_right
	walk_in_place_faster_up
	delay_16
}

movement RustboroCity_Movement_ScientistLeave {
	walk_up
}

movement RustboroCity_Movement_GoToPlayerUpgradeLeft {
	walk_left
	walk_in_place_down
	delay_16
	walk_in_place_left
}

movement RustboroCity_Movement_GoToPlayerUpgradeRight {
	walk_right
	walk_in_place_down
	delay_16
	walk_in_place_right
}

movement RustboroCity_Movement_Rival1LeaveAfterPokenav {
	walk_fast_down * 4
	walk_fast_right * 9
	set_invisible
}

text RustboroCity_Text_Rival1LetsRegister {
	format ("This is great!\N"
		"Let's register each other right now!")
}

text RustboroCity_Text_RegisteredRival1 {
	format ("{PLAYER} registered {RIVAL}\N"
		"in the POKéNAV.")
}

text RustboroCity_Text_SeeYouSoon {
	format ("Now we can call each other whenever we want!\N"
		"I'm going to try to catch a last minute SLAKOTH in PETALBURG WOODS.\N"
		"You should find {RIVAL2} and meet me at\NMR. BRINEY'S cottage.\p"
		"See you soon!")
}

