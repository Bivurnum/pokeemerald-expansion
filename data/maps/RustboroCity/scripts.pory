script RustboroCity_EventScript_RivalEncounter {
	if (var(VAR_0x8005) == 2) {
		msgbox (RustboroCity_Text_LongTimeNoSee, MSGBOX_DEFAULT)
	}
	else {
		msgbox (RustboroCity_Text_YouThoughtYoudWalkBy, MSGBOX_DEFAULT)
	}
	checkfriendchoice
	switch (var(VAR_RESULT)) {
		case SPENCER:
			trainerbattle_no_intro (TRAINER_KYLE_RUSTBORO, RustboroCity_Text_RivalEndBattleKyle)
		case BREN:
			trainerbattle_no_intro (TRAINER_SPENCER_RUSTBORO, RustboroCity_Text_RivalEndBattleSpencer)
		case KYLE:
			trainerbattle_no_intro (TRAINER_BREN_RUSTBORO, RustboroCity_Text_RivalEndBattleBren)
	}
	delay (20)
	switch (var(VAR_FACING)) {
		case DIR_NORTH:
			applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_BeginTalkUp)
		case DIR_EAST:
			applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_BeginTalkRight)
		case DIR_WEST:
			applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_BeginTalkLeft)
		case DIR_SOUTH:
			applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_BeginTalkDown)
		default:
			applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_BeginTalkUp)
	}
	waitmovement (0)
	delay (20)
	msgbox (RustboroCity_Text_GoingToAnIslandTown, MSGBOX_DEFAULT)
	closemessage
	delay (20)
	switch (var(VAR_FACING)) {
		case DIR_NORTH:
			applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_BeginTalkUp)
		case DIR_EAST:
			applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_BeginTalkRight)
		case DIR_WEST:
			applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_BeginTalkLeft)
		case DIR_SOUTH:
			applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_BeginTalkDown)
		default:
			applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_BeginTalkUp)
	}
	waitmovement (0)
	delay (20)
	msgbox (RustboroCity_Text_DevonWantsToGiveReward, MSGBOX_DEFAULT)
	closemessage
	switch (var(VAR_0x8005)) {
		case 2:
			call (RustboroCity_EventScript_WalkAwayByFacing)
		case 7:
			applymovement (LOCALID_RIVAL2, RustboroCity_Movement_Rival2WalkAwayComeBack7)
		default:
			applymovement (LOCALID_RIVAL2, RustboroCity_Movement_Rival2WalkAwayComeBack)
	}
	waitmovement (0)
	msgbox (RustboroCity_Text_DontLeaveWithoutMe)
	closemessage
	if (var(VAR_0x8005) == 2) {
		applymovement (LOCALID_RIVAL2, RustboroCity_Movement_RivalGoToDevonTalked)
	}
	else {
		applymovement (LOCALID_RIVAL2, RustboroCity_Movement_RivalGoToDevonTriggered)
	}
	waitmovement (0)
	savebgm (MUS_DUMMY)
	fadedefaultbgm
	removeobject (LOCALID_RIVAL2)
	setflag (FLAG_HIDE_RUSTBORO_CITY_RIVAL)
	clearflag (FLAG_HIDE_RIVAL2_DEVON_2F)
	setvar (VAR_RUSTBORO_CITY_STATE, 8)
	releaseall
	end
}

script RustboroCity_EventScript_WalkAwayByFacing {
	switch (var(VAR_FACING)) {
		case DIR_SOUTH:
			applymovement (OBJ_EVENT_ID_PLAYER, RustboroCity_Movement_PlayerWatchRivalLeaveSouth)
			applymovement (LOCALID_RIVAL2, RustboroCity_Movement_Rival2WalkAwayComeBack2South)
		default:
			applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_FaceUp)
			applymovement (LOCALID_RIVAL2, RustboroCity_Movement_Rival2WalkAwayComeBack2NWE)
	}
	return
}

movement RustboroCity_Movement_Rival2WalkAwayComeBack {
	walk_fast_up * 3
	walk_in_place_fast_up * 4
	walk_fast_down *2
}

movement RustboroCity_Movement_Rival2WalkAwayComeBack2NWE {
	walk_fast_up * 3
	walk_fast_right * 3
	walk_in_place_fast_right * 4
	walk_fast_left * 2
	walk_in_place_fast_down
}

movement RustboroCity_Movement_Rival2WalkAwayComeBack2South {
	walk_fast_right
	walk_fast_up * 4
	walk_fast_right * 2
	walk_in_place_fast_right * 4
	walk_fast_left * 2
	walk_in_place_fast_down
}

movement RustboroCity_Movement_Rival2WalkAwayComeBack7 {
	walk_fast_up
	walk_fast_left
	walk_fast_up * 2
	walk_in_place_fast_up * 4
	walk_fast_down * 2
}

movement RustboroCity_Movement_RivalGoToDevonTalked {
	walk_fast_right * 3
	walk_fast_up * 4
	set_invisible
}

movement RustboroCity_Movement_RivalGoToDevonTriggered {
	walk_fast_up * 4
	set_invisible
}

movement RustboroCity_Movement_PlayerWatchRivalLeaveSouth {
	delay_8
	face_right
	delay_8
	face_up
}

text RustboroCity_Text_LongTimeNoSee {
	format ("Hey, {PLAYER}!\N"
		"Long time no see.\p"
		"{RIVAL} told me that you stomped that AQUA thug yet again.\N"
		"And this time you did it solo!\N"
		"That's impressive!\p"
		"That settles it.\N"
		"I need to see you in action.\N"
		"Time for a battle!")
}

text RustboroCity_Text_YouThoughtYoudWalkBy {
	format ("You thought you'd just walk right by without so much as a 'hello'?\N"
		"I know it's been a little while,\N but c'mon!\p"
		"{RIVAL} told me that you stomped that AQUA thug yet again.\N"
		"And this time you did it solo!\N"
		"Very impressive!\p"
		"That settles it.\N"
		"I need to see you in action.\N"
		"Time for a battle!")
}

text RustboroCity_Text_RivalEndBattleSpencer {
	format ("Would you look at that!\N"
		"I lost!")
}

text RustboroCity_Text_RivalEndBattleBren {
	format ("You and your POKéMON have got some good teamwork!")
}

text RustboroCity_Text_RivalEndBattleKyle {
	format ("Huh.\n"
		"I lost again.")
}

text RustboroCity_Text_GoingToAnIslandTown {
	format ("What's that?\N"
		"You and {RIVAL} are going to ask an old sailor to take you to an island town?\p"
		"That sounds awesome!\N"
		"I want to come too!")
}

text RustboroCity_Text_DevonWantsToGiveReward {
	format ("What's that?\N"
		"The president of the DEVON corporation wants to give me a reward?\p"
		"Wow! I'd better go to the DEVON building!\N"
		"Thanks for letting me know.")
}

text RustboroCity_Text_DontLeaveWithoutMe {
	format ("I'll meet you at the old man's cottage when I'm done.\N"
		"Don't leave without me!")
}

