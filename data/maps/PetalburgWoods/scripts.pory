raw `
.set LOCALID_GRUNT, 3
.set LOCALID_DEVON_EMPLOYEE, 4
.set LOCALID_RIVAL2, 14
`
mapscripts PetalburgWoods_MapScripts {
	
}

script PetalburgWoods_EventScript_DevonResearcherLeft {
	lockall
	clearflag (FLAG_HIDE_PETALBURG_WOODS_RIVAL2)
	addobject (LOCALID_RIVAL2)
	msgbox (PetalburgWoods_Text_HoldUpPlayer, MSGBOX_DEFAULT)
	closemessage
	turnobject (OBJ_EVENT_ID_PLAYER, DIR_SOUTH)
	applymovement (LOCALID_RIVAL2, PetalburgWoods_Movement_Rival2ApproachBeforeDevonLeft)
	waitmovement (0)
	turnobject (OBJ_EVENT_ID_PLAYER, DIR_EAST)
	msgbox (PetalburgWoods_Text_DidYouHearThat)
	closemessage
	turnobject (OBJ_EVENT_ID_PLAYER, DIR_NORTH)
	turnobject (LOCALID_RIVAL2, DIR_NORTH)
	playse (SE_SUDOWOODO_SHAKE)
	waitse
	call (PetalburgWoods_EventScript_DevonResearcherIntro)
	applymovement (LOCALID_DEVON_EMPLOYEE, PetalburgWoods_Movement_DevonResearcherFleeToPlayer)
	waitmovement (0)
	msgbox (PetalburgWoods_Text_YouHaveToHelpMe, MSGBOX_DEFAULT)
	closemessage
	applymovement (LOCALID_GRUNT, PetalburgWoods_Movement_AquaApproachPlayerLeft)
	waitmovement (0)
	msgbox (PetalburgWoods_Text_NoOneCrossesTeamAqua, MSGBOX_DEFAULT)
	turnobject (OBJ_EVENT_ID_PLAYER, DIR_EAST)
	applymovement (LOCALID_RIVAL2, PetalburgWoods_Movement_Rival2PrepareToFightLeft)
	waitmovement (0)
	turnobject (LOCALID_DEVON_EMPLOYEE, DIR_WEST)
	call (PetalburgWoods_EventScript_PrepareForGruntBattle)
	applymovement (LOCALID_GRUNT, PetalburgWoods_Movement_AquaBackOff)
	waitmovement (0)
	call (PetalburgWoods_EventScript_DevonResearcherPostBattle)
	applymovement (LOCALID_DEVON_EMPLOYEE, PetalburgWoods_Movement_GiveGreatBallsLeft)
	waitmovement (0)
	call (PetalburgWoods_EventScript_GiveGreatBalls)
	applymovement (LOCALID_DEVON_EMPLOYEE, PetalburgWoods_Movement_DevonResearcherExit)
	waitmovement (0)
	call (PetalburgWoods_EventScript_RemoveDevonResearcher)
	turnobject (LOCALID_RIVAL2, DIR_WEST)
	turnobject (OBJ_EVENT_ID_PLAYER, DIR_EAST)
	goto (PetalburgWoods_EventScript_RivalLeave)
	end
}

script PetalburgWoods_EventScript_DevonResearcherRight {
	lockall
	clearflag (FLAG_HIDE_PETALBURG_WOODS_RIVAL2)
	addobject (LOCALID_RIVAL2)
	setobjectxy (LOCALID_DEVON_EMPLOYEE, 26, 17)
	setobjectxy (LOCALID_GRUNT, 26, 17)
	msgbox (PetalburgWoods_Text_HoldUpPlayer, MSGBOX_DEFAULT)
	closemessage
	turnobject (OBJ_EVENT_ID_PLAYER, DIR_SOUTH)
	applymovement (LOCALID_RIVAL2, PetalburgWoods_Movement_Rival2ApproachBeforeDevonRight)
	waitmovement (0)
	turnobject (OBJ_EVENT_ID_PLAYER, DIR_WEST)
	msgbox (PetalburgWoods_Text_DidYouHearThat)
	closemessage
	turnobject (OBJ_EVENT_ID_PLAYER, DIR_NORTH)
	turnobject (LOCALID_RIVAL2, DIR_NORTH)
	playse (SE_SUDOWOODO_SHAKE)
	waitse
	call (PetalburgWoods_EventScript_DevonResearcherIntro)
	applymovement (LOCALID_DEVON_EMPLOYEE, PetalburgWoods_Movement_DevonResearcherFleeToPlayer)
	waitmovement (0)
	msgbox (PetalburgWoods_Text_YouHaveToHelpMe, MSGBOX_DEFAULT)
	applymovement (LOCALID_GRUNT, PetalburgWoods_Movement_AquaApproachPlayerRight)
	waitmovement (0)
	msgbox (PetalburgWoods_Text_NoOneCrossesTeamAqua, MSGBOX_DEFAULT)
	closemessage
	turnobject (OBJ_EVENT_ID_PLAYER, DIR_WEST)
	applymovement (LOCALID_RIVAL2, PetalburgWoods_Movement_Rival2PrepareToFightRight)
	waitmovement (0)
	turnobject (LOCALID_DEVON_EMPLOYEE, DIR_EAST)
	call (PetalburgWoods_EventScript_PrepareForGruntBattle)
	applymovement (LOCALID_GRUNT, PetalburgWoods_Movement_AquaBackOff)
	waitmovement (0)
	call (PetalburgWoods_EventScript_DevonResearcherPostBattle)
	applymovement (LOCALID_DEVON_EMPLOYEE, PetalburgWoods_Movement_GiveGreatBallsRight)
	waitmovement (0)
	call (PetalburgWoods_EventScript_GiveGreatBalls)
	applymovement (LOCALID_DEVON_EMPLOYEE, PetalburgWoods_Movement_DevonResearcherExit)
	waitmovement (0)
	call (PetalburgWoods_EventScript_RemoveDevonResearcher)
	turnobject (OBJ_EVENT_ID_PLAYER, DIR_WEST)
	turnobject (LOCALID_RIVAL2, DIR_EAST)
	goto (PetalburgWoods_EventScript_RivalLeave)
	end
}

script PetalburgWoods_EventScript_DevonResearcherIntro {
	applymovement (LOCALID_DEVON_EMPLOYEE, PetalburgWoods_Movement_DevonResearcherLookAround)
	waitmovement (0)
	msgbox (PetalburgWoods_Text_NotAOneToBeFound, MSGBOX_DEFAULT)
	closemessage
	applymovement (LOCALID_DEVON_EMPLOYEE, PetalburgWoods_Movement_DevonResearcherApproachPlayer)
	waitmovement (0)
	msgbox (PetalburgWoods_Text_HaveYouSeenShroomish, MSGBOX_DEFAULT)
	closemessage
	playbgm (MUS_ENCOUNTER_AQUA, TRUE)
	applymovement (LOCALID_GRUNT, PetalburgWoods_Movement_AquaEntrance)
	waitmovement (0)
	msgbox (PetalburgWoods_Text_IWasGoingToAmbushYou, MSGBOX_DEFAULT)
	closemessage
	applymovement (LOCALID_GRUNT, PetalburgWoods_Movement_AquaApproachResearcher)
	waitmovement (0)
	applymovement (LOCALID_DEVON_EMPLOYEE, Common_Movement_WalkInPlaceFasterUp)
	waitmovement (0)
	msgbox (PetalburgWoods_Text_HandOverThosePapers, MSGBOX_DEFAULT)
	closemessage
	return
}

script PetalburgWoods_EventScript_PrepareForGruntBattle {
	msgbox (PetalburgWoods_Text_TakeHimOnTogether, MSGBOX_DEFAULT)
	closemessage
	//savebgm (MUS_ENCOUNTER_AQUA)
	special (SavePlayerParty)
	fadescreen (FADE_TO_BLACK)
	special (ChooseHalfPartyForBattle)
	waitstate
	goto_if_ne (VAR_RESULT, 0, PetalburgWoods_EventScript_BeginGruntBattle)
	goto (PetalburgWoods_EventScript_QuitPartySelect)
	return
}

script PetalburgWoods_EventScript_QuitPartySelect {
	msgbox (PetalburgWoods_Text_NotGetOutOfThisOne)
	closemessage
	special (SavePlayerParty)
	fadescreen (FADE_TO_BLACK)
	special (ChooseHalfPartyForBattle)
	waitstate
	goto_if_ne (VAR_RESULT, 0, PetalburgWoods_EventScript_BeginGruntBattle)
	goto (PetalburgWoods_EventScript_QuitPartySelect)
	end
}

script PetalburgWoods_EventScript_BeginGruntBattle {
	turnobject (OBJ_EVENT_ID_PLAYER, DIR_NORTH)
	turnobject (LOCALID_RIVAL2, DIR_NORTH)
	msgbox ("Bring it on!", MSGBOX_DEFAULT)
	closemessage
	checkfriendchoice
	switch (var(VAR_RESULT)) {
		case SPENCER:
			multi_2_vs_1 (TRAINER_GRUNT_PETALBURG_WOODS, PetalburgWoods_Text_YoureKiddingMe, PARTNER_KYLE_WOODS)
		case BREN:
			multi_2_vs_1 (TRAINER_GRUNT_PETALBURG_WOODS, PetalburgWoods_Text_YoureKiddingMe, PARTNER_SPENCER_WOODS)
		case KYLE:
			multi_2_vs_1 (TRAINER_GRUNT_PETALBURG_WOODS, PetalburgWoods_Text_YoureKiddingMe, PARTNER_BREN_WOODS)
	}
	return
}

script PetalburgWoods_EventScript_DevonResearcherPostBattle {
	msgbox (PetalburgWoods_Text_YouveGotSomeNerve, MSGBOX_DEFAULT)
	closemessage
	turnobject (LOCALID_DEVON_EMPLOYEE, DIR_NORTH)
	fadedefaultbgm
	applymovement (LOCALID_GRUNT, PetalburgWoods_Movement_AquaRunAway)
	waitmovement (0)
	removeobject (LOCALID_GRUNT)
	applymovement (LOCALID_DEVON_EMPLOYEE, Common_Movement_WalkInPlaceFasterDown)
	waitmovement (0)
	msgbox (PetalburgWoods_Text_ThatWasAwfullyClose, MSGBOX_DEFAULT)
	closemessage
	return
}

script PetalburgWoods_EventScript_GiveGreatBalls {
	giveitem (ITEM_GREAT_BALL)
	goto_if_eq (VAR_RESULT, FALSE, PetalburgWoods_EventScript_BagFull)
	goto (PetalburgWoods_EventScript_DevonResearcherFinish)
	end
}

script PetalburgWoods_EventScript_BagFull {
	msgbox (PetalburgWoods_Text_YoureLoadedWithItems, MSGBOX_DEFAULT)
	goto (PetalburgWoods_EventScript_DevonResearcherFinish)
	end
}

script PetalburgWoods_EventScript_DevonResearcherFinish {
	msgbox (PetalburgWoods_Text_TeamAquaAfterSomethingInRustboro, MSGBOX_DEFAULT)
	applymovement (LOCALID_DEVON_EMPLOYEE, PetalburgWoods_Movement_DevonResearcherStartExit)
	waitmovement (0)
	msgbox (PetalburgWoods_Text_ICantBeWastingTime, MSGBOX_DEFAULT)
	closemessage
	return
}

script PetalburgWoods_EventScript_RemoveDevonResearcher {
	removeobject (LOCALID_DEVON_EMPLOYEE)
	setvar (VAR_PETALBURG_WOODS_STATE, 1)
	setflag (FLAG_HIDE_ROUTE_104_RIVAL1)
	return
}

script PetalburgWoods_EventScript_RivalLeave {
	msgbox (PetalburgWoods_Text_BattleWasFun, MSGBOX_DEFAULT)
	closemessage
	turnobject (OBJ_EVENT_ID_PLAYER, DIR_NORTH)
	applymovement (LOCALID_RIVAL2, PetalburgWoods_Movement_Rival2Exit)
	waitmovement (0)
	removeobject (LOCALID_RIVAL2)
	setflag (FLAG_HIDE_PETALBURG_WOODS_RIVAL2)
	setflag (FLAG_HIDE_ROUTE_104_RIVAL1)
	setflag (FLAG_HIDE_ROUTE_101_RIVAL2)
	waitmovement(0)
	releaseall
	end
}

text PetalburgWoods_Text_HoldUpPlayer {
	format ("Hold up, {PLAYER}!")
}

text PetalburgWoods_Text_DidYouHearThat {
	format ("It's much darker inside this forest.\N"
		"Things might be lurking in the shadows, waiting to ambush you.\p"
		"Wait!\N… … …\N"
		"Do you hear that?")
}

text PetalburgWoods_Text_BattleWasFun {
	format ("It was so awesome to battle alongside you!\N"
		"We sure make a great team.\p"
		"I hope that guy will be okay.\N"
		"It sound like there might be some more trouble brewing.\p"
		"Regardless, you've definitely shown that you can handle yourself.\N"
		"The rest of this forest should be a cake walk.\p"
		"That guy said there were SHROOMISH in these woods? "
		"I'd sure like to get one for my POKéDEX.\p"
		"I'll see you later. I have a SHROOMISH to find!")
}

text PetalburgWoods_Text_TakeHimOnTogether {
	format ("This guy looks pretty tough.\N"
		"Let's take him on together!\p"
		"Pick the POKéMON you want to use.")
}

text PetalburgWoods_Text_NotGetOutOfThisOne {
	format ("I don't think we're getting out of this one.\N"
		"Go on, pick the POKéMON you'd like to battle with.")
}

movement PetalburgWoods_Movement_Rival2ApproachBeforeDevonLeft {
	walk_fast_right * 9
	walk_up * 3
	walk_in_place_faster_left
}

movement PetalburgWoods_Movement_Rival2ApproachBeforeDevonRight {
	walk_fast_right * 8
	walk_up * 3
	walk_in_place_faster_right
}

movement PetalburgWoods_Movement_DevonResearcherLookAround {
	walk_down * 3
	face_right
	delay_16
	delay_8
	face_left
	delay_16
	delay_8
	face_down
	delay_16
	face_right
	delay_16
	delay_8
	face_up
	delay_16
}

movement PetalburgWoods_Movement_DevonResearcherExit {
	walk_fast_up
	walk_fast_up
	walk_fast_up
	walk_fast_up
	walk_fast_up
	delay_16 * 2
}

movement PetalburgWoods_Movement_DevonResearcherApproachPlayer {
	delay_16
	face_player
	walk_down
	walk_down
}

movement PetalburgWoods_Movement_DevonResearcherApproachPlayerRight {
	delay_16
	face_player
	walk_right
	walk_down
	walk_down
}

movement PetalburgWoods_Movement_DevonResearcherExitRight {
	walk_fast_left
	walk_fast_up
	walk_fast_up
	walk_fast_up
	walk_fast_up
	walk_fast_up
	walk_fast_up
	walk_fast_up
}

movement PetalburgWoods_Movement_WatchResearcherLeave {
	delay_16
	delay_16
	walk_in_place_faster_up
}

movement PetalburgWoods_Movement_DevonResearcherFleeToPlayer {
	walk_in_place_faster_down * 4
}

movement PetalburgWoods_Movement_DevonResearcherFleeToPlayerRight {
	walk_fast_down
	walk_fast_right
	walk_in_place_faster_up
}

movement PetalburgWoods_Movement_DevonResearcherStartExit {
	walk_in_place_faster_right
	delay_16
	delay_16
	delay_16
	emote_exclamation_mark
	face_up
	delay_16
}

movement PetalburgWoods_Movement_AquaApproachResearcher {
	walk_fast_down
	walk_fast_down
}

movement PetalburgWoods_Movement_AquaBackOff {
	lock_facing_direction
	walk_up
	unlock_facing_direction
}

movement PetalburgWoods_Movement_AquaRunAway {
	walk_fast_up
	walk_fast_up
	walk_fast_up
	walk_fast_up
	walk_fast_up
	delay_16
	delay_16
}

movement PetalburgWoods_Movement_AquaApproachResearcherRight {
	walk_fast_down
	walk_fast_down
	walk_fast_right
	walk_in_place_faster_down
}

movement PetalburgWoods_Movement_AquaEntrance {
	walk_down
	walk_down
	delay_16
	delay_16
}

movement PetalburgWoods_Movement_AquaApproachPlayerLeft {
	walk_left
	walk_down
}

movement PetalburgWoods_Movement_AquaApproachPlayerRight {
	walk_right
	walk_down
}

movement PetalburgWoods_Movement_GiveGreatBallsLeft {
	walk_in_place_down * 2
	walk_left
	walk_in_place_down * 2
}

movement PetalburgWoods_Movement_GiveGreatBallsRight {
	walk_in_place_down * 2
	walk_right
	walk_in_place_down * 2
}

movement PetalburgWoods_Movement_Rival2Exit {
	walk_fast_up * 6
	set_invisible
}

movement PetalburgWoods_Movement_Rival2PrepareToFightRight {
	walk_in_place_right * 2
}

movement PetalburgWoods_Movement_Rival2PrepareToFightLeft {
	walk_in_place_left * 2
}

raw `
PetalburgWoods_EventScript_Boy1::
	msgbox PetalburgWoods_Text_StayOutOfTallGrass, MSGBOX_NPC
	end

PetalburgWoods_EventScript_Boy2::
	msgbox PetalburgWoods_Text_HiddenItemsExplanation, MSGBOX_NPC
	end

PetalburgWoods_EventScript_Girl::
	lock
	faceplayer
	goto_if_set FLAG_RECEIVED_MIRACLE_SEED, PetalburgWoods_EventScript_ExplainMiracleSeed
	msgbox PetalburgWoods_Text_TryUsingThisItem, MSGBOX_DEFAULT
	giveitem ITEM_MIRACLE_SEED
	goto_if_eq VAR_RESULT, FALSE, Common_EventScript_ShowBagIsFull
	setflag FLAG_RECEIVED_MIRACLE_SEED
	release
	end

PetalburgWoods_EventScript_ExplainMiracleSeed::
	msgbox PetalburgWoods_Text_MiracleSeedExplanation, MSGBOX_DEFAULT
	release
	end

PetalburgWoods_EventScript_Sign1::
	msgbox PetalburgWoods_Text_TrainerTipsExperience, MSGBOX_SIGN
	end

PetalburgWoods_EventScript_Sign2::
	msgbox PetalburgWoods_Text_TrainerTipsPP, MSGBOX_SIGN
	end

PetalburgWoods_EventScript_Lyle::
	trainerbattle_single TRAINER_LYLE, PetalburgWoods_Text_GoBugPokemonTeam, PetalburgWoods_Text_ICouldntWin
	msgbox PetalburgWoods_Text_ImOutOfPokeBalls, MSGBOX_AUTOCLOSE
	end

PetalburgWoods_EventScript_James::
	trainerbattle_single TRAINER_JAMES_1, PetalburgWoods_Text_InstantlyPopularWithBugPokemon, PetalburgWoods_Text_CantBePopularIfILose, PetalburgWoods_EventScript_TryRegisterJames
	specialvar VAR_RESULT, ShouldTryRematchBattle
	goto_if_eq VAR_RESULT, TRUE, PetalburgWoods_EventScript_JamesRematch
	setvar VAR_0x8004, TRAINER_JAMES_1
	specialvar VAR_RESULT, IsTrainerRegistered
	goto_if_eq VAR_RESULT, FALSE, PetalburgWoods_EventScript_TryRegisterJames2
	msgbox PetalburgWoods_Text_PeopleRespectYou, MSGBOX_DEFAULT
	release
	end

PetalburgWoods_EventScript_TryRegisterJames::
	special PlayerFaceTrainerAfterBattle
	waitmovement 0
	goto_if_set FLAG_HAS_MATCH_CALL, PetalburgWoods_EventScript_RegisterJames
	release
	end

PetalburgWoods_EventScript_RegisterJames::
	msgbox PetalburgWoods_Text_IWantRematch1, MSGBOX_DEFAULT
	register_matchcall TRAINER_JAMES_1
	release
	end

PetalburgWoods_EventScript_TryRegisterJames2::
	goto_if_set FLAG_HAS_MATCH_CALL, PetalburgWoods_EventScript_RegisterJames2
	msgbox PetalburgWoods_Text_PeopleRespectYou, MSGBOX_DEFAULT
	release
	end

PetalburgWoods_EventScript_RegisterJames2::
	msgbox PetalburgWoods_Text_IWantRematch2, MSGBOX_DEFAULT
	register_matchcall TRAINER_JAMES_1
	release
	end

PetalburgWoods_EventScript_JamesRematch::
	trainerbattle_rematch TRAINER_JAMES_1, PetalburgWoods_Text_MyPokemonHaveGrown, PetalburgWoods_Text_CantBePopularIfLose
	msgbox PetalburgWoods_Text_IveBeenTrainingHard, MSGBOX_AUTOCLOSE
	end

PetalburgWoods_Text_NotAOneToBeFound:
	.string "Hmmm…\n"
	.string "Not a one to be found…$"

PetalburgWoods_Text_HaveYouSeenShroomish:
	.string "Hello, have you kids seen any POKéMON\n"
	.string "called SHROOMISH around here?\p"
	.string "I really love that POKéMON.$"

PetalburgWoods_Text_IWasGoingToAmbushYou:
	.string "I was going to ambush you, but you\n"
	.string "had to dawdle in PETALBURG WOODS\l"
	.string "forever, didn't you?\p"
	.string "I got sick of waiting, so here I am!$"

PetalburgWoods_Text_HandOverThosePapers:
	.string "You! DEVON RESEARCHER!\p"
	.string "Hand over those papers!$"

PetalburgWoods_Text_YouHaveToHelpMe:
	.string "Aiyeeeh!\p"
	.string "You're both POKéMON TRAINERS,\naren't you?\p"
	.string "You've got to help me, please!$"

PetalburgWoods_Text_NoOneCrossesTeamAqua:
	.string "Hunh? What do you think you're doing?\n"
	.string "What, you're going to protect him?\p"
	.string "No one who crosses TEAM AQUA\n"
	.string "gets any mercy, not even kids!\p"
	.string "Come on and battle me!$"

PetalburgWoods_Text_YoureKiddingMe:
	.string "You're kidding me! You're tough!$"

PetalburgWoods_Text_YouveGotSomeNerve:
	.string "Grrr… You've got some nerve\n"
	.string "meddling with TEAM AQUA!\l"
	.string "Come on and battle me again!\p"
	.string "I wish I could say that, but I'm out of\n"
	.string "POKéMON…\p"
	.string "And, hey, we of TEAM AQUA are also\n"
	.string "after something in RUSTBORO.\p"
	.string "I'll let you go today!$"

PetalburgWoods_Text_ThatWasAwfullyClose:
	.string "Whew…\n"
	.string "That was awfully close!\p"
	.string "Thanks to you two, he didn't rob me\n"
	.string "of these important papers.\p"
	.string "I know, I'll give you a GREAT BALL as\n"
	.string "my thanks!$"

PetalburgWoods_Text_TeamAquaAfterSomethingInRustboro:
	.string "Didn't that TEAM AQUA thug say\n"
	.string "they were after something in\l"
	.string "RUSTBORO, too?$"

PetalburgWoods_Text_ICantBeWastingTime:
	.string "Uh-oh! It's a crisis!\n"
	.string "I can't be wasting time!$"

PetalburgWoods_Text_YoureLoadedWithItems:
	.string "You're loaded with items.\n"
	.string "I can't give you this GREAT BALL.$"

PetalburgWoods_Text_GoBugPokemonTeam:
	.string "I caught a whole bunch of POKéMON!\p"
	.string "Go, go, go!\n"
	.string "My BUG POKéMON team!$"

PetalburgWoods_Text_ICouldntWin:
	.string "I have all these POKéMON,\n"
	.string "but I couldn't win…$"

PetalburgWoods_Text_ImOutOfPokeBalls:
	.string "I caught a bunch of POKéMON.\n"
	.string "Now I'm out of POKé BALLS.$"

PetalburgWoods_Text_InstantlyPopularWithBugPokemon:
	.string "If you take BUG POKéMON to school,\n"
	.string "you get to be instantly popular!$"

PetalburgWoods_Text_CantBePopularIfILose:
	.string "I can't be popular if I lose.$"

PetalburgWoods_Text_PeopleRespectYou:
	.string "If you have a big BUG POKéMON,\n"
	.string "people respect you for it.$"

PetalburgWoods_Text_IWantRematch1:
	.string "I want a rematch when my BUG\n"
	.string "POKéMON grow up!\p"
	.string "I'm registering you in my POKéNAV!$"

PetalburgWoods_Text_IWantRematch2:
	.string "I want a rematch when my BUG \n"
	.string "POKéMON grow up!\p"
	.string "I'm registering you in my POKéNAV!$"

PetalburgWoods_Text_MyPokemonHaveGrown:
	.string "My BUG POKéMON have grown.\n"
	.string "I'll be popular again.$"

PetalburgWoods_Text_CantBePopularIfLose:
	.string "I can't be popular if I lose.$"

PetalburgWoods_Text_IveBeenTrainingHard:
	.string "You get to be popular if you have\n"
	.string "strong POKéMON, right?\l"
	.string "So, I've been training hard.$"

PetalburgWoods_Text_StayOutOfTallGrass:
	.string "Yo, there!\n"
	.string "Your POKéMON doing okay?\p"
	.string "If your POKéMON are weak and you want\n"
	.string "to avoid battles, you should stay out\l"
	.string "of tall grass.$"

PetalburgWoods_Text_HiddenItemsExplanation:
	.string "Sometimes, there are things on the\n"
	.string "ground even if you can't see them.\p"
	.string "That's why I always check where I'm\n"
	.string "walking.$"

PetalburgWoods_Text_TryUsingThisItem:
	.string "Oh, neat!\n"
	.string "That's the BADGE from RUSTBORO GYM!\p"
	.string "You must be a TRAINER.\n"
	.string "You should try using this item.$"

PetalburgWoods_Text_MiracleSeedExplanation:
	.string "It's a MIRACLE SEED.\n"
	.string "If a POKéMON holds that item, its\l"
	.string "GRASS-type moves become stronger.\p"
	.string "Besides MIRACLE SEED, I think there are\n"
	.string "other convenient items for POKéMON\l"
	.string "to hold.$"

PetalburgWoods_Text_TrainerTipsExperience:
	.string "TRAINER TIPS\p"
	.string "Any POKéMON that appears even once\n"
	.string "in a battle is awarded EXP Points.\p"
	.string "To raise a weak POKéMON, put it at the\n"
	.string "left of the team list.\p"
	.string "As soon as a battle starts, switch it\n"
	.string "out. It will earn EXP Points without\l"
	.string "being exposed to any harm.$"

PetalburgWoods_Text_TrainerTipsPP:
	.string "TRAINER TIPS\p"
	.string "In addition to Hit Points (HP), POKéMON\n"
	.string "have Power Points (PP) that are used to\l"
	.string "make moves during battle.\p"
	.string "If a POKéMON runs out of PP, it must be\n"
	.string "taken to a POKéMON CENTER.$"

