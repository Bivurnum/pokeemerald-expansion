const LOCALID_TWIN = 1
const LOCALID_MOM = 4
const LOCALID_RIVAL = 7
const LOCALID_BIRCH = 8

	// State descriptions for VAR_LITTLEROOT_TOWN_STATE
	// 1: Met Rival
	// 2: Saving Birch
	// 3: Received Pokedex
	// 4: Received Running Shoes

	// State descriptions for VAR_LITTLEROOT_INTRO_STATE
	// 1: In truck Spencer
	// 2: In truck Bren
	// 3: In truck Kyle
	// 4: Entered house
	// 5: Told to go set clock
	// 6: Entered 2F to set clock
	// 7: Set clock
	// 8: Told to go meet rival

	// State descriptions for VAR_LITTLEROOT_HOUSES_STATE_BREN
	//                    and VAR_LITTLEROOT_HOUSES_STATE_SPENCER
	//                    and VAR_LITTLEROOT_HOUSES_STATE_KYLE
	// 1: On Truck (and is corresponding friend)
	// 2: Met Rival's Mom (and is corresponding friend)
	// 3: Set second friend in bedroom
	// 18: Entered Hall of Fame
	// 19: Completed Lati TV / SS Ticket event
	// 20: Exited house after above event

	// State descriptions for VAR_LITTLEROOT_RIVAL_STATE
	// 1: Chose to enter friend's truck
	// 2: Jumped into friend's truck
	// 3: Woke friend
	// 4: Exited friend's truck
	// 5: All trucks hidden
	// 6: Talked to 2F friend
	// 19: Met Rival
	// 20: Received Pokedex

mapscripts LittlerootTown_MapScripts {
	MAP_SCRIPT_ON_TRANSITION {
		setflag (FLAG_VISITED_LITTLEROOT_TOWN)
		call (Common_EventScript_SetupRivalGfxId)
		call (LittlerootTown_EventScript_CheckForTwin)
		if (var(VAR_LITTLEROOT_INTRO_STATE) == 2) {
			setobjectxyperm (LOCALID_MOM, 14, 8)
		}
		if (var(VAR_LITTLEROOT_INTRO_STATE) == 3) {
			setobjectxyperm (LOCALID_MOM, 17, 15)
		}
		if (var(VAR_LITTLEROOT_TOWN_STATE) == 3) {
			checkfriendchoice
			if (var(VAR_RESULT) != KYLE) {
				clearflag (FLAG_HIDE_LITTLEROOT_TOWN_MOM_OUTSIDE)
				setobjectmovementtype (LOCALID_MOM, MOVEMENT_TYPE_FACE_DOWN)
			}
			switch (var(VAR_RESULT)) {
				case SPENCER:
					setobjectxyperm (LOCALID_MOM, 5, 9)
				case BREN:
					setobjectxyperm (LOCALID_MOM, 14, 9)
				case KYLE:
					setobjectxyperm (LOCALID_MOM, 17, 16)
			}
		}
		if (var(VAR_LITTLEROOT_HOUSES_STATE_SPENCER) == 19) {
			setvar (VAR_LITTLEROOT_HOUSES_STATE_BREN, 20)
			setvar (VAR_LITTLEROOT_HOUSES_STATE_SPENCER, 20)
			setvar (VAR_LITTLEROOT_HOUSES_STATE_KYLE, 20)
		}
		if (var(VAR_LITTLEROOT_HOUSES_STATE_BREN) == 19) {
			setvar (VAR_LITTLEROOT_HOUSES_STATE_BREN, 20)
			setvar (VAR_LITTLEROOT_HOUSES_STATE_SPENCER, 20)
			setvar (VAR_LITTLEROOT_HOUSES_STATE_KYLE, 20)
		}
		if (var(VAR_LITTLEROOT_HOUSES_STATE_KYLE) == 19) {
			setvar (VAR_LITTLEROOT_HOUSES_STATE_BREN, 20)
			setvar (VAR_LITTLEROOT_HOUSES_STATE_SPENCER, 20)
			setvar (VAR_LITTLEROOT_HOUSES_STATE_KYLE, 20)
		}
		if (var(VAR_OLDALE_RIVAL_STATE) == 1) {
			setvar (VAR_OLDALE_RIVAL_STATE, 2)
			setflag (FLAG_HIDE_OLDALE_TOWN_RIVAL)
		}
		if (var(VAR_LITTLEROOT_RIVAL_STATE) == 19) {
			setflag (FLAG_RIVAL_LEFT_FOR_ROUTE103)
		}
		if (var(VAR_DEX_UPGRADE_JOHTO_STARTER_STATE) == 1) {
			setflag (FLAG_HIDE_MAP_NAME_POPUP)
		}
		if (var(VAR_DEX_UPGRADE_JOHTO_STARTER_STATE) == 2) {
			setvar (VAR_DEX_UPGRADE_JOHTO_STARTER_STATE, 3)
		}
	}
	MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_LITTLEROOT_INTRO_STATE, 1: LittlerootTown_EventScript_StepOffTruckSpencer
		VAR_LITTLEROOT_INTRO_STATE, 2: LittlerootTown_EventScript_StepOffTruckBren
		VAR_LITTLEROOT_INTRO_STATE, 3: LittlerootTown_EventScript_StepOffTruckKyle
		VAR_LITTLEROOT_RIVAL_STATE, 2: LittlerootTown_EventScript_JumpOffFriendTruck
		VAR_LITTLEROOT_RIVAL_STATE, 3: LittlerootTown_EventScript_JumpOffFriendTruck
		VAR_DEX_UPGRADE_JOHTO_STARTER_STATE, 1: LittlerootTown_EventScript_BeginDexUpgradeScene
	]
	MAP_SCRIPT_ON_WARP_INTO_MAP_TABLE [
		VAR_DEX_UPGRADE_JOHTO_STARTER_STATE, 1: LittlerootTown_EventScript_SetRivalBirchPosForDexUpgrade
	]
}

script LittlerootTown_EventScript_CheckForTwin {
	call_if_unset (FLAG_RESCUED_BIRCH, LittlerootTown_EventScript_SetTwinPos)
	return
}

script LittlerootTown_EventScript_SetTwinPos {
	goto_if_eq (VAR_LITTLEROOT_TOWN_STATE, 0, LittlerootTown_EventScript_SetTwinGuardingRoutePos)
	setobjectxyperm (LOCALID_TWIN, 10, 1)
	setobjectmovementtype (LOCALID_TWIN, MOVEMENT_TYPE_FACE_UP)
	return
}

script LittlerootTown_EventScript_SetTwinGuardingRoutePos {
	setobjectxyperm (LOCALID_TWIN, 7, 2)
	setobjectmovementtype (LOCALID_TWIN, MOVEMENT_TYPE_FACE_DOWN)
	return
}

script LittlerootTown_EventScript_StepOffTruckSpencer {
	lockall
	setvar (VAR_0x8004, 5)
	setvar (VAR_0x8005, 8)
	call (LittlerootTown_EventScript_GoInsideWithMom)
	setflag (FLAG_HIDE_LITTLEROOT_TOWN_SPENCERS_HOUSE_TRUCK)
	setvar (VAR_LITTLEROOT_HOUSES_STATE_SPENCER, 2)
	warpsilent (MAP_LITTLEROOT_TOWN_BRENDANS_HOUSE_1F, 8, 8)
	waitstate
	releaseall
	end
}

script LittlerootTown_EventScript_StepOffTruckBren {
	lockall
	setvar (VAR_0x8004, 14)
	setvar (VAR_0x8005, 8)
	call (LittlerootTown_EventScript_GoInsideWithMom)
	setflag (FLAG_HIDE_LITTLEROOT_TOWN_BRENS_HOUSE_TRUCK)
	setvar (VAR_LITTLEROOT_HOUSES_STATE_BREN, 2)
	warpsilent (MAP_LITTLEROOT_TOWN_MAYS_HOUSE_1F, 2, 8)
	waitstate
	releaseall
	end
}

script LittlerootTown_EventScript_StepOffTruckKyle {
	lockall
	setvar (VAR_0x8004, 17)
	setvar (VAR_0x8005, 15)
	call (LittlerootTown_EventScript_GoInsideWithMom)
	setflag (FLAG_HIDE_LITTLEROOT_TOWN_KYLES_HOUSE_TRUCK)
	setvar (VAR_LITTLEROOT_HOUSES_STATE_KYLE, 2)
	warpsilent (MAP_LITTLEROOT_TOWN_KYLES_HOUSE_1F, 2, 8)
	waitstate
	releaseall
	end
}

script LittlerootTown_EventScript_JumpOffFriendTruck {
	lockall
	delay (15)
	playse (SE_LEDGE)
	applymovement (OBJ_EVENT_ID_PLAYER, LittlerootTown_Movement_JumpOffFriendTruck)
	waitmovement (0)
	if (var(VAR_LITTLEROOT_RIVAL_STATE) == 2) {
		setvar (VAR_LITTLEROOT_RIVAL_STATE, 1)
	}
	else {
		setvar (VAR_LITTLEROOT_RIVAL_STATE, 4)
	}
	releaseall
	end
}

script LittlerootTown_EventScript_GoInsideWithMom {
	delay (15)
	playse (SE_LEDGE)
	applymovement (OBJ_EVENT_ID_PLAYER, LittlerootTown_Movement_PlayerStepOffTruck)
	waitmovement (0)
	opendoor (VAR_0x8004, VAR_0x8005)
	waitdooranim
	addobject (LOCALID_MOM)
	applymovement (LOCALID_MOM, LittlerootTown_Movement_MomExitHouse)
	waitmovement (0)
	closedoor (VAR_0x8004, VAR_0x8005)
	waitdooranim
	delay (10)
	applymovement (LOCALID_MOM, LittlerootTown_Movement_MomApproachPlayerAtTruck)
	waitmovement (0)
	msgbox (LittlerootTown_Text_OurNewHomeLetsGoInside, MSGBOX_DEFAULT)
	closemessage
	applymovement (LOCALID_MOM, LittlerootTown_Movement_MomApproachDoor)
	applymovement (OBJ_EVENT_ID_PLAYER, LittlerootTown_Movement_PlayerApproachDoor)
	waitmovement (0)
	opendoor (VAR_0x8004, VAR_0x8005)
	waitdooranim
	applymovement (LOCALID_MOM, LittlerootTown_Movement_MomEnterHouse)
	applymovement (OBJ_EVENT_ID_PLAYER, LittlerootTown_Movement_PlayerEnterHouse)
	waitmovement (0)
	setflag (FLAG_HIDE_LITTLEROOT_TOWN_MOM_OUTSIDE)
	setvar (VAR_LITTLEROOT_INTRO_STATE, 4)
	hideobjectat (OBJ_EVENT_ID_PLAYER, 0)
	closedoor (VAR_0x8004, VAR_0x8005)
	waitdooranim
	clearflag (FLAG_HIDE_LITTLEROOT_TOWN_FAT_MAN)
	clearflag (FLAG_HIDE_MAP_NAME_POPUP)
	return
}

script LittlerootTown_EventScript_EnterTruck {
	lockall
	getplayerxy (VAR_0x8004, VAR_0x8005)
	if (var(VAR_0x8004) == 4 || var(VAR_0x8004) == 13 || var(VAR_0x8004) == 16) {
		if (var(VAR_LITTLEROOT_RIVAL_STATE) >= 3 || var(VAR_LITTLEROOT_RIVAL_STATE) >= 3 || var(VAR_LITTLEROOT_RIVAL_STATE) >= 3) {
			msgbox ("They must've locked the truck.")
		}
		else {
			msgbox ("Would you like to enter the truck?", MSGBOX_YESNO)
			switch (var(VAR_RESULT)) {
				case YES:
					delay (15)
					playse (SE_LEDGE)
					applymovement (OBJ_EVENT_ID_PLAYER, LittlerootTown_Movement_PlayerEnterTruck)
					waitmovement (0)
					//fadescreen (FADE_TO_BLACK)
					setvar (VAR_LITTLEROOT_RIVAL_STATE, 1)
					checkfriendchoice
					switch (var(VAR_0x8004)) {
						case 4:
							switch (var(VAR_RESULT)) {
								case BREN:
									setvar (VAR_LITTLEROOT_HOUSES_STATE_KYLE, 2)
								case KYLE:
									setvar (VAR_LITTLEROOT_HOUSES_STATE_BREN, 2)
							}
							setvar (VAR_0x8009, 4)
							clearflag (FLAG_HIDE_SPENCER_IN_TRUCK)
							setflag (FLAG_HIDE_LITTLEROOT_TOWN_BRENS_HOUSE_TRUCK)
							setflag (FLAG_HIDE_LITTLEROOT_TOWN_KYLES_HOUSE_TRUCK)
							setdynamicwarp (MAP_LITTLEROOT_TOWN, 3, 10)
						case 13:
							switch (var(VAR_RESULT)) {
								case SPENCER:
									setvar (VAR_LITTLEROOT_HOUSES_STATE_KYLE, 2)
								case KYLE:
									setvar (VAR_LITTLEROOT_HOUSES_STATE_SPENCER, 2)
							}
							setvar (VAR_0x8009, 5)
							clearflag (FLAG_HIDE_BREN_IN_TRUCK)
							setflag (FLAG_HIDE_LITTLEROOT_TOWN_SPENCERS_HOUSE_TRUCK)
							setflag (FLAG_HIDE_LITTLEROOT_TOWN_KYLES_HOUSE_TRUCK)
							setdynamicwarp (MAP_LITTLEROOT_TOWN, 12, 10)
						case 16:
							switch (var(VAR_RESULT)) {
								case BREN:
									setvar (VAR_LITTLEROOT_HOUSES_STATE_SPENCER, 2)
								case SPENCER:
									setvar (VAR_LITTLEROOT_HOUSES_STATE_BREN, 2)
							}
							setvar (VAR_0x8009, 6)
							clearflag (FLAG_HIDE_KYLE_IN_TRUCK)
							setflag (FLAG_HIDE_LITTLEROOT_TOWN_SPENCERS_HOUSE_TRUCK)
							setflag (FLAG_HIDE_LITTLEROOT_TOWN_BRENS_HOUSE_TRUCK)
							setdynamicwarp (MAP_LITTLEROOT_TOWN, 15, 17)
					}
					setvar (VAR_LITTLEROOT_RIVAL_STATE, 2)
					warp (MAP_INSIDE_OF_TRUCK, 4, 2)
					waitstate
					end
				case NO:
				releaseall
				end
		}
		}
	}
	else {
		msgbox ("This truck has a cool logo!")
	}
	releaseall
	end
}

movement LittlerootTown_Movement_MomExitHouse {
	walk_down
}

movement LittlerootTown_Movement_MomApproachPlayerAtTruck {
	walk_down
	walk_in_place_faster_left
}

movement LittlerootTown_Movement_MomApproachDoor {
	delay_16
	delay_8
	walk_up
}

movement LittlerootTown_Movement_MomEnterHouse {
	walk_up
	set_invisible
}

movement LittlerootTown_Movement_PlayerApproachDoor {
	delay_16
	delay_8
	walk_right
	walk_in_place_faster_up
}

movement LittlerootTown_Movement_PlayerEnterHouse {
	walk_up * 2
}

movement LittlerootTown_Movement_PlayerStepOffTruck {
	jump_right
	delay_16 * 3
}

movement LittlerootTown_Movement_PlayerEnterTruck {
	jump_left
}

movement LittlerootTown_Movement_JumpOffFriendTruck {
	jump_right
}

script LittlerootTown_EventScript_BeginDexUpgradeScene {
	lockall
	playse (SE_PIN)
	applymovement (LOCALID_BIRCH, Common_Movement_ExclamationMark)
	waitmovement (0)
	delay (80)
	msgbox (LittlerootTown_Text_BirchSomethingToShowYouAtLab, MSGBOX_DEFAULT)
	closemessage
	clearflag (FLAG_HIDE_LITTLEROOT_TOWN_RIVAL)
	clearflag (FLAG_HIDE_LITTLEROOT_TOWN_BIRCH)
	delay (20)
	clearflag (FLAG_HIDE_MAP_NAME_POPUP)
	warp (MAP_LITTLEROOT_TOWN_PROFESSOR_BIRCHS_LAB, 6, 5)
	waitstate
	releaseall
	end
}

script LittlerootTown_EventScript_SetRivalBirchPosForDexUpgrade {
	addobject (LOCALID_BIRCH)
	addobject (LOCALID_RIVAL)
	checkfriendchoice
	switch (var(VAR_RESULT)) {
		case SPENCER:
			setobjectxy (LOCALID_RIVAL, 6, 10)
			setobjectxy (LOCALID_BIRCH, 5, 10)
		case BREN:
			setobjectxy (LOCALID_RIVAL, 13, 10)
			setobjectxy (LOCALID_BIRCH, 14, 10)
		case KYLE:
			setobjectxy (LOCALID_RIVAL, 17, 17)
			setobjectxy (LOCALID_BIRCH, 18, 17)
	}
	end
}

script LittlerootTown_EventScript_FatMan {
	lock
	faceplayer
	msgbox (LittlerootTown_Text_CanUsePCToStoreItems, MSGBOX_NPC)
	release
	end
}

script LittlerootTown_EventScript_Boy {
	lock
	faceplayer
	msgbox (LittlerootTown_Text_BirchSpendsDaysInLab, MSGBOX_NPC)
	release
	end
}

script LittlerootTown_EventScript_Twin {
	lock
	faceplayer
	goto_if_set (FLAG_ADVENTURE_STARTED, LittlerootTown_EventScript_GoodLuck)
	goto_if_set (FLAG_RESCUED_BIRCH, LittlerootTown_EventScript_YouSavedBirch)
	if (var(VAR_LITTLEROOT_TOWN_STATE) == 1) {
		special (GetPlayerBigGuyGirlString)
		msgbox (LittlerootTown_Text_CanYouGoSeeWhatsHappening, MSGBOX_DEFAULT)
		closemessage
		applymovement (LOCALID_TWIN, Common_Movement_FaceOriginalDirection)
		waitmovement (0)
		setvar (VAR_LITTLEROOT_TOWN_STATE, 2)
		release
		end
	}
	msgbox (LittlerootTown_Text_IfYouGoInGrassPokemonWillJumpOut, MSGBOX_DEFAULT)
	release
	end
}

script LittlerootTown_EventScript_YouSavedBirch {
	special (GetPlayerBigGuyGirlString)
	msgbox (LittlerootTown_Text_YouSavedBirch, MSGBOX_DEFAULT)
	release
	end
}

script LittlerootTown_EventScript_GoodLuck {
	msgbox (LittlerootTown_Text_GoodLuckCatchingPokemon, MSGBOX_DEFAULT)
	release
	end
}

script LittlerootTown_EventScript_NeedPokemonTriggerLeft {
	lockall
	applymovement (LOCALID_TWIN, LittlerootTown_Movement_TwinApproachPlayerLeft)
	waitmovement (0)
	call (LittlerootTown_EventScript_DangerousWithoutPokemon)
	applymovement (LOCALID_TWIN, LittlerootTown_Movement_TwinReturnLeft)
	waitmovement (0)
	releaseall
	end
}

script LittlerootTown_EventScript_NeedPokemonTriggerRight {
	lockall
	applymovement (LOCALID_TWIN, LittlerootTown_Movement_TwinApproachPlayerRight)
	waitmovement (0)
	call (LittlerootTown_EventScript_DangerousWithoutPokemon)
	applymovement (LOCALID_TWIN, LittlerootTown_Movement_TwinReturnRight)
	waitmovement (0)
	releaseall
	end
}

script LittlerootTown_EventScript_DangerousWithoutPokemon {
	msgbox (LittlerootTown_Text_IfYouGoInGrassPokemonWillJumpOut, MSGBOX_DEFAULT)
	closemessage
	applymovement (LOCALID_TWIN, LittlerootTown_Movement_TwinPushPlayerFromRoute)
	applymovement (OBJ_EVENT_ID_PLAYER, LittlerootTown_Movement_PushPlayerBackFromRoute)
	waitmovement (0)
	msgbox (LittlerootTown_Text_DangerousIfYouDontHavePokemon, MSGBOX_DEFAULT)
	closemessage
}

movement LittlerootTown_Movement_TwinApproachPlayerLeft {
	face_right
	delay_8
	disable_jump_landing_ground_effect
	jump_in_place_right
	delay_8
	walk_fast_right * 4
	walk_fast_up * 2
	walk_fast_left
	face_down
}

movement LittlerootTown_Movement_TwinPushPlayerFromRoute {
	walk_down
}

movement LittlerootTown_Movement_TwinReturnLeft {
	walk_right
	walk_down * 2
	walk_left * 4
	walk_up
	walk_in_place_faster_down
}

movement LittlerootTown_Movement_PushPlayerBackFromRoute {
	lock_facing_direction
	walk_down
	unlock_facing_direction
}

movement LittlerootTown_Movement_TwinApproachPlayerRight {
	face_right
	delay_8
	disable_jump_landing_ground_effect
	jump_in_place_right
	delay_8
	walk_fast_right * 3
	walk_fast_up * 2
	walk_fast_right
	face_down
}

movement LittlerootTown_Movement_TwinReturnRight {
	walk_left
	walk_down
	walk_left * 3
	walk_in_place_faster_down
}

script LittlerootTown_EventScript_GoSaveBirchTrigger {
	lockall
	applymovement (LOCALID_TWIN, Common_Movement_WalkInPlaceFasterRight)
	waitmovement (0)
	applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_WalkInPlaceFasterLeft)
	waitmovement (0)
	special (GetPlayerBigGuyGirlString)
	msgbox (LittlerootTown_Text_CanYouGoSeeWhatsHappening, MSGBOX_DEFAULT)
	closemessage
	applymovement (LOCALID_TWIN, Common_Movement_FaceOriginalDirection)
	waitmovement (0)
	setvar (VAR_LITTLEROOT_TOWN_STATE, 2)
	releaseall
	end
}

