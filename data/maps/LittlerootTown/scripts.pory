	lockall
	setvar (VAR_0x8008, 4)
	goto (LittlerootTown_EventScript_GiveRunningShoesTrigger)
	end
}

script LittlerootTown_EventScript_GiveRunningShoesTrigger5 {
	lockall
	setvar (VAR_0x8008, 5)
	goto (LittlerootTown_EventScript_GiveRunningShoesTrigger)
	end
}

script LittlerootTown_EventScript_GiveRunningShoesTrigger {
	checkfriendchoice
	if (var(VAR_RESULT) == SPENCER) {
		applymovement (LOCALID_MOM, Common_Movement_WalkInPlaceFasterRight)
		waitmovement (0)
	}
	else {
		applymovement (LOCALID_MOM, Common_Movement_WalkInPlaceFasterLeft)
		waitmovement (0)
	}
	if (var(VAR_RESULT) == SPENCER) {
		setvar (VAR_0x8009, 5)
		setvar (VAR_0x800A, 8)
	}
	if (var(VAR_RESULT) == BREN) {
		setvar (VAR_0x8009, 14)
		setvar (VAR_0x800A, 8)
	}
	if (var(VAR_RESULT) == KYLE) {
		setvar (VAR_0x8009, 17)
		setvar (VAR_0x800A, 15)
	}
	msgbox (LittlerootTown_Text_WaitPlayer, MSGBOX_DEFAULT)
	closemessage
	if (var(VAR_0x8008) <= 1) {
		switch (var(VAR_0x8008)) {
			case 0:
				applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_WalkInPlaceFasterDown)
				waitmovement (0)
				applymovement (LOCALID_MOM, LittlerootTown_Movement_MomApproachPlayer0)
			case 1:
				applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_WalkInPlaceFasterDown)
				waitmovement (0)
				applymovement (LOCALID_MOM, LittlerootTown_Movement_MomApproachPlayer1)
		}
	}
	elif (var(VAR_RESULT) == SPENCER) {
		switch (var(VAR_0x8008)) {
			case 2:
				applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_WalkInPlaceFasterLeft)
				waitmovement (0)
				applymovement (LOCALID_MOM, LittlerootTown_Movement_MomApproachPlayerMale2)
			case 3:
				applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_WalkInPlaceFasterLeft)
				waitmovement (0)
				applymovement (LOCALID_MOM, LittlerootTown_Movement_MomApproachPlayerMale3)
			case 4:
				applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_WalkInPlaceFasterLeft)
				waitmovement (0)
				applymovement (LOCALID_MOM, LittlerootTown_Movement_MomApproachPlayerMale4)
			case 5:
				applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_WalkInPlaceFasterLeft)
				waitmovement (0)
				applymovement (LOCALID_MOM, LittlerootTown_Movement_MomApproachPlayerMale5)
		}
	}
	elif (var(VAR_RESULT) == BREN) {
		switch (var(VAR_0x8008)) {
			case 2:
				applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_WalkInPlaceFasterRight)
				waitmovement (0)
				applymovement (LOCALID_MOM, LittlerootTown_Movement_MomApproachPlayerFemale2)
			case 3:
				applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_WalkInPlaceFasterRight)
				waitmovement (0)
				applymovement (LOCALID_MOM, LittlerootTown_Movement_MomApproachPlayerFemale3)
			case 4:
				applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_WalkInPlaceFasterRight)
				waitmovement (0)
				applymovement (LOCALID_MOM, LittlerootTown_Movement_MomApproachPlayerFemale4)
			case 5:
				applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_WalkInPlaceFasterRight)
				waitmovement (0)
				applymovement (LOCALID_MOM, LittlerootTown_Movement_MomApproachPlayerFemale5)
		}
	}
	waitmovement (0)
	call (LittlerootTown_EventScript_GiveRunningShoes)
	if (var(VAR_0x8008) <= 1) {
		switch (var(VAR_0x8008)) {
			case 0:
				applymovement (LOCALID_MOM, LittlerootTown_Movement_MomReturnHome0)
				waitmovement (0)
			case 1:
				applymovement (LOCALID_MOM, LittlerootTown_Movement_MomReturnHome1)
				waitmovement (0)
		}
	}
	elif (var(VAR_RESULT) == SPENCER) {
		switch (var(VAR_0x8008)) {
			case 2:
				applymovement (LOCALID_MOM, LittlerootTown_Movement_MomReturnHomeMale2)
				waitmovement (0)
				opendoor (VAR_0x8009, VAR_0x800A)
				waitdooranim
				applymovement (LOCALID_MOM, LittlerootTown_Movement_MomExitThroughDoor)
				waitmovement (0)
				hideobjectat (LOCALID_MOM, MAP_LITTLEROOT_TOWN)
				closedoor (VAR_0x8009, VAR_0x800A)
				waitdooranim
			case 3:
				applymovement (LOCALID_MOM, LittlerootTown_Movement_MomReturnHomeMale3)
				waitmovement (0)
				opendoor (VAR_0x8009, VAR_0x800A)
				waitdooranim
				applymovement (LOCALID_MOM, LittlerootTown_Movement_MomExitThroughDoor)
				waitmovement (0)
				hideobjectat (LOCALID_MOM, MAP_LITTLEROOT_TOWN)
				closedoor (VAR_0x8009, VAR_0x800A)
				waitdooranim
			case 4:
				applymovement (LOCALID_MOM, LittlerootTown_Movement_MomReturnHomeMale4)
				waitmovement (0)
				opendoor (VAR_0x8009, VAR_0x800A)
				waitdooranim
				applymovement (LOCALID_MOM, LittlerootTown_Movement_MomExitThroughDoor)
				waitmovement (0)
				hideobjectat (LOCALID_MOM, MAP_LITTLEROOT_TOWN)
				closedoor (VAR_0x8009, VAR_0x800A)
				waitdooranim
			case 5:
				applymovement (LOCALID_MOM, LittlerootTown_Movement_MomReturnHomeMale5)
				waitmovement (0)
				opendoor (VAR_0x8009, VAR_0x800A)
				waitdooranim
				applymovement (LOCALID_MOM, LittlerootTown_Movement_MomExitThroughDoor)
				waitmovement (0)
				hideobjectat (LOCALID_MOM, MAP_LITTLEROOT_TOWN)
				closedoor (VAR_0x8009, VAR_0x800A)
				waitdooranim
		}
	}
	elif (var(VAR_RESULT) == BREN) {
		switch (var(VAR_0x8008)) {
			case 2:
				applymovement (LOCALID_MOM, LittlerootTown_Movement_MomReturnHomeFemale2)
				waitmovement (0)
				opendoor (VAR_0x8009, VAR_0x800A)
				waitdooranim
				applymovement (LOCALID_MOM, LittlerootTown_Movement_MomExitThroughDoor)
				waitmovement (0)
				hideobjectat (LOCALID_MOM, MAP_LITTLEROOT_TOWN)
				closedoor (VAR_0x8009, VAR_0x800A)
				waitdooranim
			case 3:
				applymovement (LOCALID_MOM, LittlerootTown_Movement_MomReturnHomeFemale3)
				waitmovement (0)
				opendoor (VAR_0x8009, VAR_0x800A)
				waitdooranim
				applymovement (LOCALID_MOM, LittlerootTown_Movement_MomExitThroughDoor)
				waitmovement (0)
				hideobjectat (LOCALID_MOM, MAP_LITTLEROOT_TOWN)
				closedoor (VAR_0x8009, VAR_0x800A)
				waitdooranim
			case 4:
				applymovement (LOCALID_MOM, LittlerootTown_Movement_MomReturnHomeFemale4)
				waitmovement (0)
				opendoor (VAR_0x8009, VAR_0x800A)
				waitdooranim
				applymovement (LOCALID_MOM, LittlerootTown_Movement_MomExitThroughDoor)
				waitmovement (0)
				hideobjectat (LOCALID_MOM, MAP_LITTLEROOT_TOWN)
				closedoor (VAR_0x8009, VAR_0x800A)
				waitdooranim
			case 5:
				applymovement (LOCALID_MOM, LittlerootTown_Movement_MomReturnHomeFemale5)
				waitmovement (0)
				opendoor (VAR_0x8009, VAR_0x800A)
				waitdooranim
				applymovement (LOCALID_MOM, LittlerootTown_Movement_MomExitThroughDoor)
				waitmovement (0)
				hideobjectat (LOCALID_MOM, MAP_LITTLEROOT_TOWN)
				closedoor (VAR_0x8009, VAR_0x800A)
				waitdooranim
		}
	}
	removeobject (LOCALID_MOM)
	setflag (FLAG_SYS_B_DASH)
	setvar (VAR_LITTLEROOT_TOWN_STATE, 4)
	release
	end
}

script LittlerootTown_EventScript_Mom {
	lock
	faceplayer
	checkfriendchoice
	if (var(VAR_RESULT) == SPENCER) {
		setvar (VAR_0x8009, 5)
		setvar (VAR_0x800A, 8)
	}
	if (var(VAR_RESULT) == BREN) {
		setvar (VAR_0x8009, 14)
		setvar (VAR_0x800A, 8)
	}
	if (var(VAR_RESULT) == KYLE) {
		setvar (VAR_0x8009, 17)
		setvar (VAR_0x800A, 15)
	}
	call (LittlerootTown_EventScript_GiveRunningShoes)
	applymovement (LOCALID_MOM, Common_Movement_WalkInPlaceFasterUp)
	waitmovement (0)
	opendoor (VAR_0x8009, VAR_0x800A)
	waitdooranim
	applymovement (LOCALID_MOM, LittlerootTown_Movement_MomExitThroughDoor)
	waitmovement (0)
	hideobjectat (LOCALID_MOM, MAP_LITTLEROOT_TOWN)
	closedoor (VAR_0x8009, VAR_0x800A)
	waitdooranim
	removeobject (LOCALID_MOM)
	setflag (FLAG_SYS_B_DASH)
	setvar (VAR_LITTLEROOT_TOWN_STATE, 4)
	release
	end
}

script LittlerootTown_EventScript_GiveRunningShoes {
	msgbox (LittlerootTown_Text_WearTheseRunningShoes, MSGBOX_DEFAULT)
	playfanfare (MUS_OBTAIN_ITEM)
	message (LittlerootTown_Text_SwitchShoesWithRunningShoes)
	waitfanfare
	setflag (FLAG_RECEIVED_RUNNING_SHOES)
	msgbox (LittlerootTown_Text_ExplainRunningShoes, MSGBOX_DEFAULT)
	msgbox (LittlerootTown_Text_ComeHomeIfAnythingHappens, MSGBOX_DEFAULT)
	closemessage
	delay (30)
	return
}

movement LittlerootTown_Movement_MomApproachPlayer0 {
	walk_up * 6
}

movement LittlerootTown_Movement_MomApproachPlayer1 {
	walk_up * 6
}

movement LittlerootTown_Movement_MomApproachPlayerMale2 {
	walk_right * 4
}

movement LittlerootTown_Movement_MomApproachPlayerMale3 {
	walk_right * 5
}

movement LittlerootTown_Movement_MomApproachPlayerMale4 {
	walk_right * 2
}

movement LittlerootTown_Movement_MomApproachPlayerMale5 {
	walk_right * 3
}

movement LittlerootTown_Movement_MomApproachPlayerFemale2 {
	walk_left * 3
}

movement LittlerootTown_Movement_MomApproachPlayerFemale3 {
	walk_left * 2
}

movement LittlerootTown_Movement_MomApproachPlayerFemale4 {
	walk_left * 5
}

movement LittlerootTown_Movement_MomApproachPlayerFemale5 {
	walk_left * 4
}

movement LittlerootTown_Movement_MomReturnHome0 {
	walk_down * 5
}

movement LittlerootTown_Movement_MomReturnHome1 {
	walk_down * 5
}

movement LittlerootTown_Movement_MomReturnHomeMale2 {
	walk_left * 4
	walk_in_place_faster_up
}

movement LittlerootTown_Movement_MomReturnHomeMale3 {
	walk_left * 5
	walk_in_place_faster_up
}

movement LittlerootTown_Movement_MomReturnHomeMale4 {
	walk_left * 2
	walk_in_place_faster_up
}

movement LittlerootTown_Movement_MomReturnHomeMale5 {
	walk_left * 3
	walk_in_place_faster_up
}

movement LittlerootTown_Movement_MomReturnHomeFemale2 {
	walk_right * 3
	walk_in_place_faster_up
}

movement LittlerootTown_Movement_MomReturnHomeFemale3 {
	walk_right * 2
	walk_in_place_faster_up
}

movement LittlerootTown_Movement_MomReturnHomeFemale4 {
	walk_right * 5
	walk_in_place_faster_up
}

movement LittlerootTown_Movement_MomReturnHomeFemale5 {
	walk_right * 4
	walk_in_place_faster_up
}

movement LittlerootTown_Movement_MomExitThroughDoor {
	walk_up
}

text LittlerootTown_Text_OurNewHomeLetsGoInside {
	"MOM: {PLAYER}, we're here, honey!\p"
	"It must be tiring riding with our things\n"
	"in the moving truck.\p"
	"Well, this is LITTLEROOT TOWN.\p"
	"How do you like it?\n"
	"This is our new home!\p"
	"It has a quaint feel, but it seems to be\n"
	"an easy place to live, don't you think?\p"
	"And, you get your own room, {PLAYER}!\n"
	"Let's go inside."
}

text LittlerootTown_Text_WaitPlayer {
	"MOM: Wait, {PLAYER}!"
}

text LittlerootTown_Text_WearTheseRunningShoes {
	"MOM: {PLAYER}! {PLAYER}! Did you\n"
	"introduce yourself to PROF. BIRCH?\p"
	"Oh! What an adorable POKéMON!\n"
	"You got it from PROF. BIRCH. How nice!\p"
	"You're your father's child, all right.\n"
	"You look good together with POKéMON!\p"
	"Here, honey! If you're going out on an\n"
	"adventure, wear these RUNNING SHOES.\p"
	"They'll put a zip in your step!"
}

text LittlerootTown_Text_SwitchShoesWithRunningShoes {
	"{PLAYER} switched shoes with the\n"
	"RUNNING SHOES."
}

text LittlerootTown_Text_ExplainRunningShoes {
	"MOM: {PLAYER}, those shoes came with\n"
	"instructions.\p"
	"“Press the B Button while wearing these\n"
	"RUNNING SHOES to run extra-fast!\p"
	"“Slip on these RUNNING SHOES and race\n"
	"in the great outdoors!”"
}

text LittlerootTown_Text_ComeHomeIfAnythingHappens {
	"… … … … … … … …\n"
	"… … … … … … … …\p"
	"To think that you have your very own\n"
	"POKéMON now…\l"
	"Your father will be overjoyed.\p"
	"…But please be careful.\n"
	"If anything happens, you can come home.\p"
	"Go on, go get them, honey!"
}

text LittlerootTown_Text_CanUsePCToStoreItems {
	"If you use a PC, you can store items\n"
	"and POKéMON.\p"
	"The power of science is staggering!"
}

text LittlerootTown_Text_BirchSpendsDaysInLab {
	"PROF. BIRCH spends days in his LAB\n"
	"studying, then he'll suddenly go out in\l"
	"the wild to do more research…\p"
	"When does PROF. BIRCH spend time\n"
	"at home?"
}

text LittlerootTown_Text_IfYouGoInGrassPokemonWillJumpOut {
	"Um, um, um!\p"
	"If you go outside and go in the grass,\n"
	"wild POKéMON will jump out!"
}

text LittlerootTown_Text_DangerousIfYouDontHavePokemon {
	"It's dangerous if you don't have\n"
	"your own POKéMON."
}

text LittlerootTown_Text_CanYouGoSeeWhatsHappening {
	"Um, hi!\p"
	"There are scary POKéMON outside!\n"
	"I can hear their cries!\p"
	"I want to go see what's going on,\n"
	"but I don't have any POKéMON…\p"
	"Can you go see what's happening\n"
	"for me?"
}

text LittlerootTown_Text_YouSavedBirch {
	"You saved PROF. BIRCH!\n"
	"I'm so glad!"
}

text LittlerootTown_Text_GoodLuckCatchingPokemon {
	"Are you going to catch POKéMON?\n"
	"Good luck!"
}

text LittlerootTown_Text_TownSign {
	"LITTLEROOT TOWN\n"
	"“A town that can't be shaded any hue.”"
}

text LittlerootTown_Text_ProfBirchsLab {
	"PROF. BIRCH'S POKéMON LAB"
}

text LittlerootTown_Text_BirchSomethingToShowYouAtLab {
	"PROF. BIRCH: Well, well, {PLAYER}{KUN}!\n"
	"That was good work out there!\p"
	"I knew there was something special\n"
	"about you when I first saw you,\l"
	"but I never expected this.\p"
	"Oh, yes. Do you still have the POKéDEX\n"
	"I gave you?\p"
	"I have something to show you.\n"
	"Let's go to my LAB."
}
