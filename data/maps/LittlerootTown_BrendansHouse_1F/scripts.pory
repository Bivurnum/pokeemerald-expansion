const LOCALID_MOM = 1
const LOCALID_RIVAL_MOM = 4
const LOCALID_RIVAL = 6

mapscripts LittlerootTown_BrendansHouse_1F_MapScripts {
	MAP_SCRIPT_ON_LOAD {
		if (var(VAR_LITTLEROOT_INTRO_STATE) < 7) {
			setmetatile (5, 4, METATILE_BrendansMaysHouse_MovingBox_Open, TRUE)
			setmetatile (5, 2, METATILE_BrendansMaysHouse_MovingBox_Closed, TRUE)
		}
		call_if_set (FLAG_RECEIVED_RUNNING_SHOES, LittlerootTown_BrendansHouse_1F_EventScript_CheckShowShoesManual)
	}
	MAP_SCRIPT_ON_TRANSITION {
		switch (var(VAR_LITTLEROOT_INTRO_STATE)) {
			case 4:
				setobjectxyperm (LOCALID_MOM, 9, 8)
				setobjectmovementtype (LOCALID_MOM, MOVEMENT_TYPE_FACE_UP)
			case 6:
				setobjectxyperm (LOCALID_MOM, 8, 4)
				setobjectmovementtype (LOCALID_MOM, MOVEMENT_TYPE_FACE_UP)
			case 7:
				setobjectxyperm (LOCALID_MOM, 4, 5)
				setobjectmovementtype (LOCALID_MOM, MOVEMENT_TYPE_FACE_UP)
		}
	}
	MAP_SCRIPT_ON_FRAME_TABLE [
		VAR_LITTLEROOT_INTRO_STATE, 4 {
			lockall
			setvar (VAR_0x8004, LOCALID_MOM)
			setvar (VAR_0x8005, SPENCER)
			goto (PlayersHouse_1F_EventScript_EnterHouseMovingIn)
		}
		VAR_LITTLEROOT_INTRO_STATE, 6 {
			lockall
			msgbox (PlayersHouse_1F_Text_GoSetTheClock, MSGBOX_DEFAULT)
			closemessage
			applymovement (OBJ_EVENT_ID_PLAYER, LittlerootTown_BrendansHouse_1F_Movement_PushTowardStairs)
			applymovement (LOCALID_MOM, LittlerootTown_BrendansHouse_1F_Movement_PushTowardStairs)
			waitmovement (0)
			warp (MAP_LITTLEROOT_TOWN_BRENDANS_HOUSE_2F, 7, 1)
			waitstate
			releaseall
		}
		VAR_LITTLEROOT_INTRO_STATE, 7 {
			lockall
			special (TurnOnTVScreen)
			setvar (VAR_0x8004, MALE)
			setvar (VAR_0x8005, LOCALID_MOM)
			goto (PlayersHouse_1F_EventScript_PetalburgGymReportMale)
		}
		VAR_LITTLEROOT_HOUSES_STATE_SPENCER, 1 {
			lockall
			playse (SE_PIN)
			applymovement (LOCALID_RIVAL_MOM, Common_Movement_ExclamationMark)
			waitmovement (0)
			applymovement (LOCALID_RIVAL_MOM, Common_Movement_Delay48)
			waitmovement (0)
			applymovement (OBJ_EVENT_ID_PLAYER, Common_Movement_WalkInPlaceFasterLeft)
			applymovement (LOCALID_RIVAL_MOM, LittlerootTown_BrendansHouse_1F_Movement_RivalMomApproach)
			waitmovement (0)
			special (GetRivalSonDaughterString)
			msgbox (RivalsHouse_1F_Text_OhYoureTheNewNeighborSpencer, MSGBOX_DEFAULT)
			setflag (FLAG_MET_RIVAL_MOM)
			setvar (VAR_LITTLEROOT_HOUSES_STATE_SPENCER, 2)
			setvar (VAR_LITTLEROOT_HOUSES_STATE_BREN, 2)
			setvar (VAR_LITTLEROOT_HOUSES_STATE_KYLE, 2)
			checkfriendchoice
			switch (var(VAR_RESULT)) {
				case BREN:
					setflag(FLAG_HIDE_LITTLEROOT_TOWN_KYLES_HOUSE_TRUCK)
				case KYLE:
					setflag(FLAG_HIDE_LITTLEROOT_TOWN_BRENS_HOUSE_TRUCK)
			}
			releaseall
		}
		VAR_LITTLEROOT_RIVAL_STATE, 4 {
			setvar (VAR_LITTLEROOT_RIVAL_STATE, 5)
			setflag (FLAG_HIDE_LITTLEROOT_TOWN_SPENCERS_HOUSE_TRUCK)
			setflag (FLAG_HIDE_LITTLEROOT_TOWN_BRENS_HOUSE_TRUCK)
			setflag (FLAG_HIDE_LITTLEROOT_TOWN_KYLES_HOUSE_TRUCK)
		}
		VAR_LITTLEROOT_HOUSES_STATE_SPENCER, 18: PlayersHouse_1F_EventScript_GetSSTicketAndSeeLatiTV
	]
}

// Many of the below scripts have no gender check because they assume youre in the correct house
// The below SS Ticket script uses Mays house state by accident(?), but theyre both set identically after the intro

script LittlerootTown_BrendansHouse_1F_EventScript_CheckShowShoesManual {
	checkfriendchoice
	if (var(VAR_RESULT) == SPENCER) {
		setmetatile (3, 7, METATILE_BrendansMaysHouse_BookOnTable, TRUE)
	}
	return
}

script LittlerootTown_BrendansHouse_1F_EventScript_GoSeeRoom {
	lockall
	setvar (VAR_0x8004, LOCALID_MOM)
	setvar (VAR_0x8005, MALE)
	applymovement (VAR_0x8004, Common_Movement_WalkInPlaceFasterLeft)
	waitmovement (0)
	goto (PlayersHouse_1F_EventScript_MomGoSeeRoom)
	end
}

movement LittlerootTown_BrendansHouse_1F_Movement_PushTowardStairs {
	walk_up
}
movement LittlerootTown_BrendansHouse_1F_Movement_RivalMomApproach {
	walk_down
	walk_right * 5
}

text PlayersHouse_1F_Text_IsntItNiceInHere {
	"MOM: See, {PLAYER}?\n"
	"Isn't it nice in here, too?"
}

text PlayersHouse_1F_Text_MoversPokemonGoSetClock {
	"The mover's POKéMON do all the work\n"
	"of moving us in and cleaning up after.\l"
	"This is so convenient!\p"
	"{PLAYER}, your room is upstairs.\n"
	"Go check it out, dear!\p"
	"DAD bought you a new clock to mark\n"
	"our move here.\l"
	"Don't forget to set it!"
}

text PlayersHouse_1F_Text_ArentYouInterestedInRoom {
	"MOM: Well, {PLAYER}?\p"
	"Aren't you interested in seeing your\n"
	"very own room?"
}

text PlayersHouse_1F_Text_GoSetTheClock {
	"MOM: {PLAYER}.\p"
	"Go set the clock in your room, honey."
}

text PlayersHouse_1F_Text_OhComeQuickly {
	"MOM: Oh! {PLAYER}, {PLAYER}!\n"
	"Quick! Come quickly!"
}

text PlayersHouse_1F_Text_MaybeDadWillBeOn {
	"MOM: Look! It's PETALBURG GYM!\n"
	"Maybe DAD will be on!"
}

text PlayersHouse_1F_Text_ItsOverWeMissedHim {
	"MOM: Oh… It's over.\p"
	"I think DAD was on, but we missed him.\n"
	"Too bad."
}

text PlayersHouse_1F_Text_GoIntroduceYourselfNextDoor {
	"Oh, yes.\n"
	"Your friends also moved here today.\p"
	"You should go see how they\n"
	"are settling in.\p"
	"I'm sure they'd enjoy your company\n"
	"after such a long trip."
}

text PlayersHouse_1F_Text_SeeYouHoney {
	"MOM: See you, honey!"
}

text PlayersHouse_1F_Text_DidYouMeetProfBirch {
	"MOM: Did you find your friends?"
}

text PlayersHouse_1F_Text_YouShouldRestABit {
	"MOM: How are you doing, {PLAYER}?\n"
	"You look a little tired.\p"
	"I think you should rest a bit."
}

text PlayersHouse_1F_Text_TakeCareHoney {
	"MOM: Take care, honey!"
}

text PlayersHouse_1F_Text_GotDadsBadgeHeresSomethingFromMom {
	"MOM: Oh? Did DAD give you that BADGE?\p"
	"Then here's something from your MOM!"
}

text PlayersHouse_1F_Text_DontPushYourselfTooHard {
	"Don't push yourself too hard, dear.\n"
	"You can always come home.\p"
	"Go for it, honey!"
}

text PlayersHouse_1F_Text_IsThatAPokenav {
	"MOM: What is that, honey? A POKéNAV?\n"
	"Someone from DEVON gave it to you?\p"
	"Well, honey, how about registering\n"
	"your mom?\p"
	"… … …"
}

text PlayersHouse_1F_Text_RegisteredMom {
	"Registered MOM\n"
	"in the POKéNAV."
}

text PlayersHouse_1F_Text_Vigoroth1 {
	"Fugiiiiih!"
}

text PlayersHouse_1F_Text_Vigoroth2 {
	"Huggoh, uggo uggo…"
}

text PlayersHouse_1F_Text_ReportFromPetalburgGym {
	"INTERVIEWER: …We brought you this\n"
	"report from in front of PETALBURG GYM."
}

text PlayersHouse_1F_Text_TheresAMovieOnTV {
	"There is a movie on TV.\p"
	"Two men are dancing on a big piano\n"
	"keyboard.\p"
	"Better get going!"
}

text PlayersHouse_1F_Text_RunningShoesManual {
	"It's the instruction booklet for the\n"
	"RUNNING SHOES.\p"
	"“Press the B Button to run while\n"
	"wearing your RUNNING SHOES.\p"
	"“Lace up your RUNNING SHOES and hit\n"
	"the road running!”"
}

text PlayersHouse_1F_Text_TicketFromBrineyCameForYou {
	"DAD: Hm?\p"
	"Hey, it's {PLAYER}!\p"
	"It's been a while since I saw you,\n"
	"but you look…stronger, somehow.\p"
	"That's the impression I get.\n"
	"But your old man hasn't given up yet!\p"
	"Oh, yes, I have something for you.\n"
	"This came to you from someone named\l"
	"MR. BRINEY."
}

text PlayersHouse_1F_Text_PortsInSlateportLilycove {
	"DAD: Hm, a TICKET for a ferry?\p"
	"If I recall, there are ferry ports in\n"
	"SLATEPORT and LILYCOVE."
}

text PlayersHouse_1F_Text_BetterGetBackToGym {
	"I'd better get back to PETALBURG GYM.\p"
	"MOM, thanks for looking after the house\n"
	"while I'm away."
}

text PlayersHouse_1F_Text_DadShouldStayLonger {
	"MOM: That DAD of yours…\p"
	"He comes home for the first time in a\n"
	"while, but all he talks about is POKéMON.\p"
	"He should relax and stay a little longer."
}

text PlayersHouse_1F_Text_IsThatABreakingStory {
	"MOM: Is that a breaking news story?"
}

text PlayersHouse_1F_Text_LatiEmergencyNewsFlash {
	"We bring you this emergency\n"
	"news flash!\p"
	"In various HOENN locales, there have\n"
	"been reports of a BZZT…colored\l"
	"POKéMON in flight.\p"
	"The identity of this POKéMON is\n"
	"currently unknown.\p"
	"We now return you to the regular\n"
	"movie program."
}

text PlayersHouse_1F_Text_WhatColorDidTheySay {
	"MOM: {PLAYER}, did you catch that?\p"
	"What color did the announcer say\n"
	"that POKéMON was?"
}

text PlayersHouse_1F_Text_StillUnknownPokemon {
	"MOM: Well, isn't that something!\n"
	"There are still unknown POKéMON."
}
