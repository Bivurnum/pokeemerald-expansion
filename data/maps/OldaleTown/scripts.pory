text OldaleTown_Text_GoPrepare {
	"Oh… Okay…\p"
	"Well, if you need to heal your\n"
	"POKéMON, there's a POKéMON CENTER\l"
	"right over there.\p"
	"I'll wait here until you're prepared."
}

text OldaleTown_Text_LetsDoThis {
	"Alright! Let's do this!"
}

text OldaleTown_Text_KyleDefeated {
	"BREN wasn't kidding!\n"
	"You're super strong!"
}

text OldaleTown_Text_SpencerDefeated {
	"KYLE wasn't kidding!\n"
	"You're super strong!"
}

text OldaleTown_Text_BrenDefeated {
	"SPENCER wasn't kidding!\n"
	"You're super strong!"
